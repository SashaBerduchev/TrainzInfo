@page "/locomotive/edit/{Id:int}"
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mb-10">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl shadow-xl">
        
        <div class="text-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.DirectionsTransit" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h4" Class="fw-bold">Новий локомотив</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Додавання магістрального локомотива в базу</MudText>
        </div>

        <EditForm Model="@locomotive" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />

            <MudStack Spacing="4">
            
                @* Серія локомотива *@
                <MudSelect T="string" Label="Серія" @bind-Value="locomotive.Seria"
                           Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                           Required="true" For="@(() => locomotive.Seria)"
                           HelperText="Наприклад: ДС3, ЧС4, ВЛ80">
                    @foreach (var item in SeriaList)
                    {
                        <MudSelectItem Value="@item">@item</MudSelectItem>
                    }
                </MudSelect>

                @* Номер *@
                <MudTextField Label="Номер локомотива" @bind-Value="locomotive.Number"
                              Variant="Variant.Outlined" Placeholder="001, 002..."
                              Required="true" For="@(() => locomotive.Number)" />

                @* Депо - Автозаповнення *@
                <MudAutocomplete T="string" Label="Депо" @bind-Value="locomotive.Depot"
                                 SearchFunc="@SearchDepot"
                                 Variant="Variant.Outlined"
                                 Placeholder="Почніть вводити депо..."
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true" CoerceValue="true"
                                 AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" />

                @* Конструкційна швидкість *@
                <MudNumericField Label="Конструкційна швидкість (км/год)" @bind-Value="locomotive.Speed"
                                 Variant="Variant.Outlined" Min="0" Max="200" />

                @* Фото - Перевірений метод із прихованим InputFile *@
                <div class="d-flex flex-column gap-2">
                    <InputFile id="locoFileInput" OnChange="HandleFileSelected" style="display:none" />
                
                    <MudButton HtmlTag="label"
                               for="locoFileInput"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               FullWidth="true"
                               Class="py-3 rounded-lg border-2 border-dashed">
                        Завантажити фото локомотива
                    </MudButton>

                    @if (!string.IsNullOrEmpty(imagePreview))
                    {
                        <MudPaper Elevation="0" Class="pa-2 mud-bg-background-grey rounded-lg d-flex justify-center mt-2">
                            <MudImage Src="@imagePreview" Height="180" ObjectFit="ObjectFit.Contain" Class="rounded-lg shadow-sm" />
                        </MudPaper>
                    }
                </div>

                @* Помилки збереження *@
                @if (!string.IsNullOrEmpty(errors))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="rounded-lg">
                        <strong>Помилка збереження:</strong> @errors
                    </MudAlert>
                }

                @* Кнопки дій *@
                <div class="d-flex justify-space-between align-center mt-6">
                    <MudButton Variant="Variant.Text" Color="Color.Secondary"
                               Href="/locomotives" StartIcon="@Icons.Material.Filled.ArrowBack">
                        До списку
                    </MudButton>
                
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Save"
                               Class="rounded-lg px-8 shadow-lg fw-bold">
                        Зберегти
                    </MudButton>
                </div>

            </MudStack>
        </EditForm>
    </MudPaper>
</MudContainer>


@code {
    [Parameter] public int Id { get; set; }
    private LocomotiveSetDTO locomotive = new LocomotiveSetDTO();
    private List<string> SeriaList = new List<string>();
    private List<string> DepotList = new List<string>();
    private List<string> filteredDepot = new List<string>();
    private List<string> OblList = new List<string>();
    private CancellationTokenSource debounceCts;
    private string depo;
    private string imagePreview;
    private string errors;
    private bool IsPublisherOrAdminOrSuperAdmin;
    private bool _isLoaded = false;



    protected override async Task OnInitializedAsync()
    {
        try
        {
            await CheckRoles();

            await Load();
        }
        catch (Exception ex)
        {
            errors = $"Помилка ініціалізації: {ex.Message}";
        }
        finally
        {
            // 3. Відкриваємо інтерфейс
            _isLoaded = true;
        }
    }

    private async Task Load()
    {
        SeriaList.Add("Виберіть серію");
        DepotList.Add("Виберіть депо");
        locomotive = await Http.GetFromJsonAsync<LocomotiveSetDTO>($"api/locomotives/getedit/{Id}") ?? new LocomotiveSetDTO();
        imagePreview = locomotive.ImgSrc;
        // Імітація завантаження даних — в реальному випадку виклик API
        var series = await Http.GetFromJsonAsync<List<string>>("api/locomotives/getallseries");
        var depots = await Http.GetFromJsonAsync<List<string>>("api/locomotives/getalldepots");
        var oblasts = await Http.GetFromJsonAsync<List<string>>("api/locomotives/allobl");
        SeriaList.AddRange(series ?? new List<string>());
        DepotList.AddRange(depots ?? new List<string>());
        OblList.AddRange(oblasts ?? new List<string>());
    }


    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                IsPublisherOrAdminOrSuperAdmin = roles.Contains("Admin");
                IsPublisherOrAdminOrSuperAdmin = roles.Contains("Superadmin");

            }
            else
            {
                Navigation.NavigateTo("/erroraccess");
            }
        }
    }


    private async Task HandleValidSubmit()
    {
        var result = await Http.PostAsJsonAsync("api/locomotives/update", locomotive);
        if (result.IsSuccessStatusCode)
        {
            // Тут можна викликати сервіс, який додає локомотив в базу через API
            Console.WriteLine($"Додано локомотив: {locomotive.Seria} {locomotive.Number}");
            // Після успіху — навігація назад
            Navigation.NavigateTo("/locomotives");
        }
        else
        {
            errors = await result.Content.ReadAsStringAsync();
            Console.WriteLine($"Помилка: {errors}");
        }


    }

    private async Task<IEnumerable<string>> SearchDepot(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return DepotList;

        return DepotList.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }


    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB
        var buffer = new byte[file.Size];
        await stream.ReadAsync(buffer);

        imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";

        // Зберігаємо у модель
        locomotive.ImgSrc = imagePreview;
        locomotive.ImageType = file.ContentType;
    }


}
