@page "/locomotives"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject AppConfig Config

<PageTitle>Локомотиви</PageTitle>
<h1 class="mb-4 text-center">Локомотиви</h1>

<div class="mb-3">
    @if (IsAdmin)
    {
        <button class="btn btn-info mb-2" @onclick="AddLocomotive">Додати локомотив</button>
        <button class="btn btn-info mb-2" @onclick="UpdateInfo">Оновити дані</button>
        <p><b>Кількість запитів:</b> @count</p>
    }
</div>
@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center"
         style="min-height: 60vh;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    

    <!-- Фільтри -->
    <div class="row g-2 mb-3 align-items-end">
        <div class="col-12 col-md-3">
            <label class="small fw-bold text-muted ms-1">Філія / Область</label>
            <select class="form-select mb-1" @onchange="OnFiliaChanged">
                <option value="">Всі філії</option>
                @foreach (var f in FiliaList)
                {
                    <option value="@f">@f</option>
                }
            </select>
            <select class="form-select" @onchange="OnOblastChanged">
                <option value="">Всі області</option>
                @foreach (var o in OblastList)
                {
                    <option value="@o">@o</option>
                }
            </select>
        </div>

        <div class="col-12 col-md-3">
            <label class="small fw-bold text-muted ms-1">Депо</label>
            <select class="form-select" @onchange="OnDepotChanged">
                <option value="">Всі депо</option>
                @foreach (var d in DepotList)
                {
                    <option value="@d">@d</option>
                }
            </select>
        </div>

        <div class="col-12 col-md-3">
            <label class="small fw-bold text-muted ms-1">Серія</label>
            <select class="form-select" @onchange="OnSeriaChanged">
                <option value="">Всі серії</option>
                @foreach (var s in SeriaList)
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>

        <div class="col-12 col-md-3">
            @* Кнопку можна залишити як "Скинути" або просто для краси, бо фільтр і так працює *@
            <button class="btn btn-outline-secondary w-100" @onclick="ClearFilter">
                <i class="bi bi-arrow-clockwise"></i> Скинути
            </button>
        </div>
    </div>

    <div class="mb-4">
        <button class="btn btn-secondary" @onclick="ClearFilter">Скинути фільтр</button>
    </div>

    <div class="row" id="locomotiveContainer">
        @if (locomotives is null)
        {
            <div class="col-12 text-center py-5">
                <div class="no-data-icon mb-3">🔍</div>
                <h5 class="text-muted">Локомотиви відсутні, застосуйте інший фільтр</h5>
            </div>
        }
        else
        {
            @foreach (var item in locomotives)
            {
                <div class="col-12 mb-4">
                    <div class="loco-card-modern shadow-sm border-0">
                        <div class="row g-0">
                            <div class="col-12 col-md-4 position-relative overflow-hidden">
                                <img class="loco-img"
                                     src="@(Config.ApiBaseUrl + item.ImgSrc)"
                                     alt="@item.Seria" />
                                <div class="speed-badge">
                                    ⚡ @item.Speed <small>км/год</small>
                                </div>
                            </div>

                            <div class="col-12 col-md-5 p-4 border-end-md">
                                <div class="d-flex align-items-center mb-2">
                                    <h3 class="loco-title mb-0">@item.Seria</h3>
                                    <span class="loco-number ms-2">№@item.Number</span>
                                </div>

                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="label">Філія</span>
                                        <span class="value">@item.Filia</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">Депо</span>
                                        <span class="value">@item.Depot</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">Локація</span>
                                        <span class="value">@item.Oblast, @item.City</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">Станція</span>
                                        @* Використовуємо кастомний клас для більшого шрифту станції *@
                                        <span class="value station-highlight">@item.Station</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-3 bg-light-subtle d-flex flex-column justify-content-center p-3 gap-2">
                                <button class="btn btn-main" @onclick="() => ViewDetails(item.Id)">
                                    <i class="bi bi-info-circle"></i> Детальніше
                                </button>
                                <button class="btn btn-secondary-light" @onclick="() => ViewUserPhotos(item.Seria, item.Number)">
                                    <i class="bi bi-camera"></i> Галерея
                                </button>

                                @if (IsAdminOrPublisher || IsAdmin)
                                {
                                    <div class="admin-actions mt-2 pt-2 border-top">
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (IsAdminOrPublisher)
                                            {
                                                <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => EditLocomotive(item.Id)">
                                                    ред.
                                                </button>
                                            }
                                            @if (IsAdmin)
                                            {
                                                <button class="btn btn-sm btn-outline-warning" @onclick="() => AddImage(item.Id)">+ фото</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocomotive(item.Id)">видалити</button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private List<LocomotiveDTO> locomotives = new();
    private List<LocomotiveDTO> FilteredLocomotives = new();
    private int count;

    private bool isLoading = false;
    private int currentPage = 1;
    private bool allLoaded = false;

    private string SelectedFilia = "";
    private string SelectedDepot = "";
    private string SelectedSeria = "";
    private string SelectedObl = "";

    private bool isFilterLoad = false;

    private List<string> FiliaList = new();
    private List<string> OblastList = new();
    private List<string> DepotList = new();
    private List<string> SeriaList = new();

    // Симуляція авторизації
    private bool IsLogged => true;
    private bool IsAdmin { get; set; }
    private bool IsAdminOrPublisher { get; set; }
    private string depotNameFromQuery;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        depotNameFromQuery = query["depotsName"];
        await Load();
        // Підписка на скрол через JS
        await JS.InvokeVoidAsync("addLocomotiveScrollListener", DotNetObjectReference.Create(this));
        // Завантажуємо локомотиви з API  
    }

    private async Task Load()
    {
        if (isLoading || allLoaded) return;

        isLoading = true;
        IsAdmin = false;
        IsAdminOrPublisher = false;
        try
        {
            if (depotNameFromQuery is not null)
            {
                SelectedDepot = depotNameFromQuery;
            }
            var url =
               $"api/locomotives/getlocomotives?page={currentPage}" +
               $"{(string.IsNullOrWhiteSpace(SelectedFilia) ? "" : $"&filia={Uri.EscapeDataString(SelectedFilia)}")}" +
               $"{(string.IsNullOrWhiteSpace(SelectedDepot) ? "" : $"&depot={Uri.EscapeDataString(SelectedDepot)}")}" +
               $"{(string.IsNullOrWhiteSpace(SelectedObl) ? "" : $"&oblast={Uri.EscapeDataString(SelectedObl)}")}" +
               $"{(string.IsNullOrWhiteSpace(SelectedSeria) ? "" : $"&seria={Uri.EscapeDataString(SelectedSeria)}")}";

            var locomotiveItems = await Http.GetFromJsonAsync<List<LocomotiveDTO>>(url);
            var locomotivesCount = await Http.GetFromJsonAsync<int>("/api/locomotives/getcount");
            count = locomotivesCount;
            if (locomotiveItems == null || locomotiveItems.Count == 0)
            {

                allLoaded = true;
            }
            else
            {
                locomotives.AddRange(locomotiveItems);
                FilteredLocomotives = locomotiveItems;
                //ApplyFilter(); // оновлюємо відфільтровані новини
                if (!isFilterLoad)
                {
                    var urlfilia = $"api/locomotives/getfilias{($"?filia={Uri.EscapeDataString(SelectedFilia)}")}" +
                    $"{($"&depot={Uri.EscapeDataString(SelectedDepot)}")}" +
                    $"{($"&oblast={Uri.EscapeDataString(SelectedObl)}")}" +
                    $"{( $"&seria={Uri.EscapeDataString(SelectedSeria)}")}";
                    var urldepo = $"api/locomotives/getdepots{($"?filia={Uri.EscapeDataString(SelectedFilia)}")}" +
                    $"{($"&depot={Uri.EscapeDataString(SelectedDepot)}")}" +
                    $"{($"&oblast={Uri.EscapeDataString(SelectedObl)}")}" +
                    $"{($"&seria={Uri.EscapeDataString(SelectedSeria)}")}";

                    var urlseria = $"api/locomotives/getseries{($"?filia={Uri.EscapeDataString(SelectedFilia)}")}" +
                    $"{($"&depot={Uri.EscapeDataString(SelectedDepot)}")}" +
                    $"{($"&oblast={Uri.EscapeDataString(SelectedObl)}")}" +
                    $"{($"&seria={Uri.EscapeDataString(SelectedSeria)}")}";

                    var urlobl = $"api/locomotives/getoblasts{($"?filia={Uri.EscapeDataString(SelectedFilia)}")}" +
                    $"{($"&depot={Uri.EscapeDataString(SelectedDepot)}")}" +
                    $"{($"&oblast={Uri.EscapeDataString(SelectedObl)}")}" +
                    $"{($"&seria={Uri.EscapeDataString(SelectedSeria)}")}";

                    FiliaList.AddRange(await Http.GetFromJsonAsync<List<string>>(urlfilia));
                    DepotList.AddRange(await Http.GetFromJsonAsync<List<string>>(urldepo));
                    SeriaList.AddRange(await Http.GetFromJsonAsync<List<string>>(urlseria));
                    OblastList.AddRange(await Http.GetFromJsonAsync<List<string>>(urlobl));
                    isFilterLoad = true;
                }
                currentPage++;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Помилка завантаження локомотивів: " + ex.Message);
        }

        isLoading = false;
        await CheckRoles();
        StateHasChanged();
    }

    private async Task OnFiliaChanged(ChangeEventArgs e)
    {
        SelectedFilia = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }

    private async Task OnOblastChanged(ChangeEventArgs e)
    {
        SelectedObl = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }

    private async Task OnDepotChanged(ChangeEventArgs e)
    {
        SelectedDepot = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }

    private async Task OnSeriaChanged(ChangeEventArgs e)
    {
        SelectedSeria = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }

    private async Task ApplyFilter()
    {
        // Переходим к первой странице и очищаем состояние
        currentPage = 1;
        allLoaded = false;
        locomotives.Clear();          // если хотите начать с нуля
        isFilterLoad = false;
        FiliaList.Clear();
        DepotList.Clear();
        SeriaList.Clear();
        OblastList.Clear();
        await Load();                 // загружаем первую страницу
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("revealNewLocoCards");
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                IsAdmin = roles.Contains("Admin");
                IsAdmin = roles.Contains("Superadmin");

            }
            else
            {

            }
        }
    }

    private async Task ClearFilter()
    {
        SelectedFilia = SelectedDepot = SelectedSeria = SelectedObl = "";
        isFilterLoad = false;
        FiliaList.Clear();
        DepotList.Clear();
        SeriaList.Clear();
        OblastList.Clear();
        await Load();
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("revealNewLocoCards");
    }

    private void ViewDetails(int id) => Nav.NavigateTo($"/locomotives/details/{id}");
    private void ViewUserPhotos(string seria, string number) => Nav.NavigateTo($"/userphotos/{seria}/{number}");
    private void EditLocomotive(int id) => Nav.NavigateTo($"/locomotives/edit/{id}");
    private void AddImage(int id) => Nav.NavigateTo($"/locomotives/addimage/{id}");
    private void DeleteLocomotive(int id) => Nav.NavigateTo($"/locomotives/delete/{id}");
    private void AddLocomotive() => Nav.NavigateTo("/locomotives/create");

    private async Task UpdateInfo()
    {
        var response = Http.GetStringAsync("api/locomotives/update");
        Console.WriteLine(response);
        Nav.NavigateTo("/locomotives");
    }

    [JSInvokable]
    public async Task OnScrollNearBottom()
    {
        await Load();
    }
}
