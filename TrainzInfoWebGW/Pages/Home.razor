@page "/"
@inject AppConfig Config
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>TrainzInfo</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-10">
    <div class="text-center mb-10">
        <MudText Typo="Typo.h2" Color="Color.Primary" Class="fw-bold mb-4">
            Ласкаво просимо на TrainzInfo!
        </MudText>
        <MudPaper Elevation="0" Class="pa-6 rounded-xl mud-bg-background-grey">
            <MudText Typo="Typo.h6" Class="mud-text-secondary">
                Сайт присвячено любителям залізничного транспорту: локомотиви, електропоїзди та історія залізниці.
            </MudText>
        </MudPaper>
    </div>

    <MudGrid Justify="Justify.Center" Class="mb-12">
        @foreach (var (Label, Link, Icon) in new[] {
                ("Локомотиви", "/locomotives", Icons.Material.Filled.Train),
                ("Електропоїзди", "/electric-trains", Icons.Material.Filled.ElectricBolt),
                ("Дизель-поїзди", "/diesel-trains", Icons.Material.Filled.PropaneTank),
                ("Станції", "/stations", Icons.Material.Filled.Place)
                })
        {
            <MudItem xs="6" sm="3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Info"
                           FullWidth="true"
                           Size="Size.Large"
                           StartIcon="@Icon"
                           Href="@Link"
                           Class="rounded-lg py-4">
                    @Label
                </MudButton>
            </MudItem>
        }
    </MudGrid>

    <div class="d-flex justify-center mb-10">
        <MudTextField @bind-Value="SearchText"
                      Placeholder="Пошук новин за назвою..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Clearable="true"
                      Immediate="true"
                      Class="max-w-400" />
    </div>

    <div id="newsContainer">
        @if (allNews is null)
        {
            <MudGrid>
                @foreach (var i in Enumerable.Range(0, 3))
                {
                    <MudItem xs="12" md="6" lg="4">
                        <MudCard>
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
                            <MudCardContent>
                                <MudSkeleton Width="80%" Height="42px" />
                                <MudSkeleton Width="100%" />
                                <MudSkeleton Width="100%" />
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
        else if (!filteredNews.Any())
        {
            <div class="text-center py-10">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Style="font-size: 5rem;" />
                <MudText Typo="Typo.h5" Color="Color.Secondary">Новин не знайдено</MudText>
            </div>
        }
        else
        {
            <MudGrid Spacing="6">
                @foreach (var news in filteredNews)
                {
                    <MudItem xs="12" md="6" lg="4">
                        <MudCard Elevation="4" Class="h-100 d-flex flex-column rounded-xl hover-elevate">
                            <div class="position-relative">
                                @if (!string.IsNullOrWhiteSpace(news.ImgSrc))
                                {
                                    <MudCardMedia Image="@(Config.ApiBaseUrl + news.ImgSrc)" Height="220" />
                                }
                                else
                                {
                                    <div class="d-flex align-center justify-center mud-bg-background-grey" style="height: 220px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Newspaper" Size="Size.Large" Color="Color.Default" Style="font-size: 4rem;" />
                                    </div>
                                }
                                <div class="position-absolute px-3 py-1 rounded-pill mud-theme-primary" style="bottom: 10px; right: 10px; opacity: 0.9;">
                                    <MudText Typo="Typo.caption">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                                        @DateTime.Now.ToString("dd.MM.yyyy")
                                    </MudText>
                                </div>
                            </div>

                            <MudCardContent Class="flex-grow-1">
                                <MudText Typo="Typo.h5" Class="mb-3 fw-bold">@((MarkupString)news.NameNews)</MudText>
                                <div class="mud-text-secondary mb-4 line-clamp-3">
                                    @((MarkupString)news.BaseNewsInfo)
                                </div>
                            </MudCardContent>

                            <MudCardActions Class="border-t pa-4 d-flex justify-space-between align-center">
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Primary"
                                           EndIcon="@Icons.Material.Filled.ArrowForward"
                                           Href="@($"/news/details/{news.id}")">
                                    Читати далі
                                </MudButton>

                                @if (IsAdmin)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   Href="@($"/news/edit/{news.id}")" />
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-center mt-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
    </div>
</MudContainer>

@code {
    private List<NewsDTO> allNews = new();
    private List<NewsDTO> filteredNews = new();
    private string searchText = string.Empty;
    private bool IsAdmin = false;
    private int currentPage = 1;
    private bool isLoading = false;
    private bool allLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadNews();
        // Підписка на скрол через JS
        await JS.InvokeVoidAsync("addNewsScrollListener", DotNetObjectReference.Create(this));

        await JS.InvokeVoidAsync("showNewsContainer");
    }


    private async Task LoadNews()
    {
        if (isLoading || allLoaded) return;

        isLoading = true;

        try
        {
            var newItems = await Http.GetFromJsonAsync<List<NewsDTO>>($"api/news/getnews?page={currentPage}");
            if (newItems == null || newItems.Count == 0)
            {
                allLoaded = true;
            }
            else
            {
                allNews.AddRange(newItems);
                FilterNews(); // оновлюємо відфільтровані новини
                currentPage++;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Помилка завантаження новин: " + ex.Message);
        }
        await CheckRoles();
        isLoading = false;
        StateHasChanged();
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                IsAdmin = roles.Contains("Admin");
                IsAdmin = roles.Contains("Superadmin");
            }
            else
            {

            }
        }
    }

    private void FilterNews()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredNews = allNews.ToList();
        }
        else
        {
            filteredNews = allNews
                .Where(x => x.NameNews.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            FilterNews();
        }
    }

    [JSInvokable]
    public async Task OnScrollNearBottom()
    {
        await LoadNews();
    }
}