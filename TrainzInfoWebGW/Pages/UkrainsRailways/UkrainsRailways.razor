@page "/ukrains-railways"
@using SharedDTO.DTO.GetDTO
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Філії</PageTitle>

<MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true" Class="mt-4 mb-8">
    Філії Української залізниці
</MudText>

@if (railways == null)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 60vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-4">Завантаження даних...</MudText>
    </MudStack>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudGrid Spacing="4" Justify="Justify.Center">
            @foreach (var item in railways)
            {
                <MudItem xs="12" md="6">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Info"
                               FullWidth="true"
                               Size="Size.Large"
                               OnClick="@(() => ViewDetails(item.id))"
                               Style="height: 80px; text-transform: none;"
                               Elevation="4">
                        <MudText Typo="Typo.h6">@item.Name</MudText>
                    </MudButton>
                </MudItem>
            }

            <MudItem xs="12" Class="d-flex justify-center mt-8">
                <MudImage Src="@image"
                          Alt="Мапа Укрзалізниці"
                          Fluid="true"
                          ObjectFit="ObjectFit.Cover"
                          Class="rounded-lg shadow-lg"
                          Style="max-width: 100%; border: 1px solid #eee;" />
            </MudItem>
        </MudGrid>
    </MudContainer>
}
@code {
    private List<UkrainsRailwaysDTO> railways;
    private string mainMapImgSrc = "/api/mainimage/getimage?name=MainMap"; // приклад API для картинки
    private string image;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            railways = await Http.GetFromJsonAsync<List<UkrainsRailwaysDTO>>("api/railways/railways");
            var bytes = await Http.GetByteArrayAsync(mainMapImgSrc);

            // Перетворюємо на Base64 рядок
            var base64 = Convert.ToBase64String(bytes);

            // Формуємо Data URL
            image = $"data:image/png;base64,{base64}"; // заміни image/png на свій MIME тип
        }
        catch (Exception ex)
        {
            Console.WriteLine("Помилка завантаження даних: " + ex.Message);
            railways = new List<UkrainsRailwaysDTO>();
        }
    }

    private void ViewDetails(int id)
    {
        Nav.NavigateTo($"/ukrains-railways/details/{id}");
    }
}
