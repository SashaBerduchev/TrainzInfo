@page "/mainimages/edit/{Id:int}"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AppConfig Config

<PageTitle>Оновлення зображення | TrainzInfo</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mb-10">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Navigation.NavigateTo("/mainimages"))" Class="mb-4">
        Назад до списку
    </MudButton>

    @if (isLoading)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" Class="rounded-xl" />
    }
    else if (mainImage == null)
    {
        <MudAlert Severity="Severity.Error">Зображення не знайдено</MudAlert>
    }
    else
    {
        <MudPaper Elevation="4" Class="pa-8 rounded-xl border-t-8 border-solid mud-border-primary shadow-xl">
            <div class="text-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h4" Class="fw-bold">Редагувати фото</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@mainImage.Name (ID: @Id)</MudText>
            </div>

            <MudStack Spacing="6">
                @* Поточне фото *@
                <div class="d-flex flex-column align-center">
                    <MudText Typo="Typo.caption" Class="mb-2">ПОТОЧНЕ ЗОБРАЖЕННЯ</MudText>
                    @* Використовуємо mainImage.imgSrc *@
                    <MudImage Src="@(Config.ApiBaseUrl + mainImage.ImgSrc + "?t=" + DateTime.Now.Ticks)"
                              Alt="@mainImage.Name"
                              ObjectFit="ObjectFit.Cover"
                              Height="200"
                              Class="rounded-lg shadow-md w-100" />
                </div>

                @* Вибір нового файлу *@
                <div class="d-flex flex-column gap-3">
                    <InputFile id="singleFileInput" OnChange="HandleFileSelected" style="display:none" accept=".jpg,.jpeg,.png" />
                    
                    <MudButton HtmlTag="label"
                               for="singleFileInput"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               Class="py-4 border-2 border-dashed rounded-lg">
                        Вибрати новий файл
                    </MudButton>

                    @if (!string.IsNullOrEmpty(imagePreview))
                    {
                        <div class="animate__animated animate__fadeIn">
                            <MudText Typo="Typo.caption" Class="d-block mb-2 text-center">ПЕРЕГЛЯД НОВОГО ФОТО</MudText>
                            <MudPaper Elevation="0" Class="pa-2 mud-bg-background-grey rounded-lg d-flex justify-center relative">
                                <MudImage Src="@imagePreview" Height="200" ObjectFit="ObjectFit.Contain" Class="rounded-lg shadow-sm" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               OnClick="ClearPreview" Class="absolute" Style="top: 10px; right: 10px;" />
                            </MudPaper>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       FullWidth="true"
                                       Size="Size.Large"
                                       OnClick="UploadImage"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Class="mt-4 py-3 rounded-lg fw-bold shadow-lg">
                                Зберегти зміни
                            </MudButton>
                        </div>
                    }
                </div>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public int? Id { get; set; }
    private bool isLoading = true;
    private MainImageGetDTO mainImage; // Прибрав ініціалізацію new(), щоб перевірка на null була коректною
    private string imagePreview;
    private MainImageSetDTO updateModel = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        if (Id == null) return;

        try
        {
            isLoading = true;
            mainImage = await Http.GetFromJsonAsync<MainImageGetDTO>($"api/mainimage/getimageedit/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка завантаження: " + ex.Message, Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Читаємо файл у буфер
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var buffer = new byte[file.Size];
        await stream.ReadAsync(buffer);

        imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        
        // Заповнюємо модель для відправки
        updateModel.Id = mainImage?.id ?? 0;
        updateModel.Image = imagePreview;
        updateModel.ImgType = file.ContentType;
    }

    private async Task UploadImage()
    {
        try
        {
            var response = await Http.PutAsJsonAsync("api/mainimage/update", updateModel);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Зображення успішно оновлено!", Severity.Success);
                Navigation.NavigateTo("/mainimages"); // Повертаємося до списку зображень
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add("Помилка при оновленні: " + error, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка: " + ex.Message, Severity.Error);
        }
    }

    private void ClearPreview()
    {
        imagePreview = null;
        updateModel.Image = null;
        updateModel.ImgType = null;
    }
}