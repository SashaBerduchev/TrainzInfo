@using Microsoft.AspNetCore.Components.Authorization
@using TrainzInfoShared.DTO.GetDTO

@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject NavigationManager Nav
<MudNavMenu Bordered="true" Class="mud-text-white">
    <div class="pa-4 d-flex align-center gap-3">
        <MudIcon Icon="@Icons.Material.Filled.DirectionsTransit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="fw-bold">TrainzInfo</MudText>
    </div>

    <MudDivider Class="mb-4" Style="background-color: rgba(255,255,255,0.1);" />

    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home" IconColor="Color.Inherit" Class="mud-text-white py-3" Style="font-size: 1.1rem;">Головна</MudNavLink>

    <MudNavLink Href="ukrains-railways" Icon="@Icons.Material.Filled.Map" IconColor="Color.Inherit" Class="mud-text-white py-3" Style="font-size: 1.1rem;">Українська залізниця</MudNavLink>

    <MudNavGroup Title="Рухомий склад" Icon="@Icons.Material.Filled.Train" IconColor="Color.Inherit" Expanded="true" Class="mud-text-white" Style="font-size: 1.1rem;">
        <MudNavLink Href="locomotives" Icon="@Icons.Material.Filled.DirectionsRailway" IconColor="Color.Inherit" Class="white-nav-link">
            <MudText Typo="Typo.body1" Style="font-size: 1.1rem; color: white !important;">Локомотиви</MudText>
        </MudNavLink>

        <MudNavLink Href="electric-trains" Icon="@Icons.Material.Filled.ElectricBolt" IconColor="Color.Inherit" Class="white-nav-link">
            <MudText Typo="Typo.body1" Style="font-size: 1.1rem; color: white !important;">Електропоїзди</MudText>
        </MudNavLink>

        <MudNavLink Href="diesel-trains" Icon="@Icons.Material.Filled.PropaneTank" IconColor="Color.Inherit" Class="white-nav-link">
            <MudText Typo="Typo.body1" Style="font-size: 1.1rem; color: white !important;">Дизель-поїзди</MudText>
        </MudNavLink>
    </MudNavGroup>
    <MudNavLink Href="trains" Icon="@Icons.Material.Filled.TableRows" IconColor="Color.Inherit" Class="mud-text-white py-3">
        <MudText Typo="Typo.h6" Style="font-size: 1.1rem;">Розклад поїздів</MudText>
    </MudNavLink>

    <MudNavLink Href="about" Icon="@Icons.Material.Filled.Info" IconColor="Color.Inherit" Class="mud-text-white py-3">
        <MudText Typo="Typo.h6" Style="font-size: 1.1rem;">Про нас</MudText>
    </MudNavLink>
    <MudNavLink Href="@YouTubeUrl" Target="_blank" Icon="@Icons.Custom.Brands.YouTube" IconColor="Color.Error" Class="mud-text-white py-3">
        <MudText Typo="Typo.h6" Style="font-size: 1.1rem;">YouTube канал</MudText>
    </MudNavLink>

    <MudSpacer />
    <MudDivider Class="my-2" />

    <div class="pa-2">
        <AuthorizeView>
            <Authorized>
                <MudNavGroup Title="@context.User.Identity?.Name" Icon="@Icons.Material.Filled.Person" Class="mud-text-primary">
                    <MudNavLink OnClick="Profile" Icon="@Icons.Material.Filled.Badge">Мій профіль</MudNavLink>
                    <MudNavLink OnClick="Logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">Вийти</MudNavLink>
                </MudNavGroup>
            </Authorized>
            <NotAuthorized>
                <MudStack Spacing="1" Class="px-2">
                    @* Кнопка Вхід *@
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Login"
                               OnClick="Login">
                        Вхід
                    </MudButton>

                    @* Кнопка Реєстрація — тепер теж Filled *@
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="Register">
                        Реєстрація
                    </MudButton>
                </MudStack>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <div class="d-none d-md-flex justify-center pa-4 mt-auto">
        <MudImage Src="https://trainzinfo.com.ua/api/mainimage/getimage?name=MainPhoto"
                  Alt="TrainzInfo Logo" Fluid="true" Class="rounded-lg opacity-80" Style="max-height: 60px;" />
    </div>
</MudNavMenu>
@code {
    private bool isNavCollapsed = true;
    private string? NavMenuCssClass => isNavCollapsed ? "collapse" : null;
    List<UkrainsRailwaysDTO> railways = new();
    private AuthenticationState? authState;
    private string YouTubeUrl = "https://www.youtube.com/@RailwayUkraine";

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; }
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += AuthStateChanged;
        await((CustomAuthStateProvider)AuthStateProvider).CheckAuthenticationAsync();
    }

    private async void AuthStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        StateHasChanged(); // перемальовує компонент
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= AuthStateChanged;
    }

    private void ToggleNavMenu() => isNavCollapsed = !isNavCollapsed;
    private void ExpandNav() => isNavCollapsed = false;
    private void CollapseNav() => isNavCollapsed = true;

    private void Logout() => Nav.NavigateTo("logout");
    private void Register() => Nav.NavigateTo($"/register/");
    private void Login() => Nav.NavigateTo($"/login/");
    private void Profile() => Nav.NavigateTo($"/profile/");
}
