@using Microsoft.AspNetCore.Components.Authorization
@using SharedDTO.DTO.GetDTO

@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject NavigationManager Nav


<MudNavMenu Bordered="true">
    <div class="mud-navmenu-header d-flex align-center justify-center relative mb-3 overflow-hidden"
         style="height: 140px; border-bottom: 1px solid rgba(255,255,255,0.1);">
    
        <MudButton OnClick="@(() => Nav.NavigateTo("/"))"
                   Class="absolute inset-0 z-10 w-100 h-100 pa-0 d-flex align-center justify-center"
                   Style="text-transform: none; overflow: hidden; min-width: 100%;">

            @* Задній план - розмиття для заповнення фону *@
            <div class="absolute inset-0 z-0"
                 style="background: url('https://trainzinfo.com.ua/api/mainimage/getimage?name=MainPhoto') center/cover no-repeat; filter: blur(10px) brightness(0.5); width: 100%; height: 100%;">
            </div>

            @* Основне зображення - без градієнта *@
            <MudImage Src="https://trainzinfo.com.ua/api/mainimage/getimage?name=MainPhoto"
                      Alt="TrainzInfo Header"
                      Class="z-10 w-100 h-100 opacity-95 transition-zoom"
                      Style="object-fit: cover; object-position: center; position: absolute; top: 0; left: 0;" />
        </MudButton>

    </div>
    @* Убрали жестко заданный белый цвет у разделителя *@
    <MudDivider Class="mb-4" />

    @* <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home" IconColor="Color.Inherit" Class="py-3" Style="font-size: 1.1rem;">Головна</MudNavLink> *@

    <MudNavLink Href="ukrains-railways" Icon="@Icons.Material.Filled.Map" IconColor="Color.Inherit" Class="py-3" Style="font-size: 1.1rem;">Українська залізниця</MudNavLink>

    <MudNavGroup Title="Рухомий склад" Icon="@Icons.Material.Filled.Train" IconColor="Color.Inherit" Expanded="true" Class="py-3" Style="font-size: 1.1rem;">
        @* Убрали вложенные MudText и color: white !important; *@
        <MudNavLink Href="locomotives" Icon="@Icons.Material.Filled.DirectionsRailway" IconColor="Color.Inherit" Style="font-size: 1.1rem;">Локомотиви</MudNavLink>

        <MudNavLink Href="electric-trains" Icon="@Icons.Material.Filled.ElectricBolt" IconColor="Color.Inherit" Style="font-size: 1.1rem;">Електропоїзди</MudNavLink>

        <MudNavLink Href="diesel-trains" Icon="@Icons.Material.Filled.PropaneTank" IconColor="Color.Inherit" Style="font-size: 1.1rem;">Дизель-поїзди</MudNavLink>
    </MudNavGroup>

    @* Убрали вложенные MudText для чистоты кода *@
    <MudNavLink Href="trains" Icon="@Icons.Material.Filled.TableRows" IconColor="Color.Inherit" Class="py-3" Style="font-size: 1.1rem;">Розклад поїздів</MudNavLink>

    <MudNavLink Href="about" Icon="@Icons.Material.Filled.Info" IconColor="Color.Inherit" Class="py-3" Style="font-size: 1.1rem;">Про нас</MudNavLink>

    <MudNavLink Href="@YouTubeUrl" Target="_blank" Icon="@Icons.Custom.Brands.YouTube" IconColor="Color.Error" Class="py-3" Style="font-size: 1.1rem;">YouTube канал</MudNavLink>

    <MudSpacer />
    <MudDivider Class="my-2" />

    <div class="pa-2">
        <AuthorizeView>
            <Authorized>
                <MudNavGroup Title="@context.User.Identity?.Name" Icon="@Icons.Material.Filled.Person" Class="mud-text-primary">
                    <MudNavLink OnClick="Profile" Icon="@Icons.Material.Filled.Badge">Мій профіль</MudNavLink>
                    <MudNavLink OnClick="Logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">Вийти</MudNavLink>
                </MudNavGroup>
            </Authorized>
            <NotAuthorized>
                <MudStack Spacing="1" Class="px-2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Login"
                               OnClick="Login">
                        Вхід
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="Register">
                        Реєстрація
                    </MudButton>
                </MudStack>
            </NotAuthorized>
        </AuthorizeView>
    </div>

   
</MudNavMenu>
@code {
    private bool isNavCollapsed = true;
    private string? NavMenuCssClass => isNavCollapsed ? "collapse" : null;
    List<UkrainsRailwaysDTO> railways = new();
    private AuthenticationState? authState;
    private string YouTubeUrl = "https://www.youtube.com/@RailwayUkraine";

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; }
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += AuthStateChanged;
        await ((CustomAuthStateProvider)AuthStateProvider).CheckAuthenticationAsync();
    }

    private async void AuthStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        StateHasChanged(); // перемальовує компонент
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= AuthStateChanged;
    }

    private void ToggleNavMenu() => isNavCollapsed = !isNavCollapsed;
    private void ExpandNav() => isNavCollapsed = false;
    private void CollapseNav() => isNavCollapsed = true;

    private void Logout() => Nav.NavigateTo("logout");
    private void Register() => Nav.NavigateTo($"/register/");
    private void Login() => Nav.NavigateTo($"/login/");
    private void Profile() => Nav.NavigateTo($"/profile/");
}
