@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider @ref="_mudThemeProvider" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        @* Кнопка открытия бокового меню (бургер) *@
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        <MudText Typo="Typo.h6" Class="ml-3">TrainzInfo</MudText>

        <MudSpacer />

        @* Переключатель темы: Солнце/Луна *@
        <MudToggleIconButton @bind-Toggled="@_isDarkMode"
                             Icon="@Icons.Material.Filled.WbSunny"
                             Color="Color.Inherit"
                             ToggledIcon="@Icons.Material.Filled.Brightness4"
                             ToggledColor="Color.Inherit"
                             Title="Светлая тема"
                             ToggledTitle="Темная тема" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>


@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private MudThemeProvider _mudThemeProvider = default!;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Автоматически определяем тему устройства при первом запуске
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();

            // Начинаем следить за изменениями темы в системе (Windows/Android)
            await _mudThemeProvider.WatchSystemDarkModeAsync(OnSystemPreferenceChanged);

            StateHasChanged();
        }
    }

    private Task OnSystemPreferenceChanged(bool newValue)
    {
        _isDarkMode = newValue;
        StateHasChanged();
        return Task.CompletedTask;
    }
}

