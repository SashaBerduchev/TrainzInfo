@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<MudAppBar Elevation="1" Dense="true" Color="Color.Primary" Fixed="true">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
    <MudSpacer />
    <MudImage Src="https://trainzinfo.com.ua/api/mainimage/getimage?name=MainPhoto"
              Alt="Logo" Height="35" Class="rounded-lg" />
</MudAppBar>

<MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="@DrawerVariant.Temporary" Width="280px">

    @* 1. ВІДСТУП ЗВЕРХУ: Додаємо padding-top, щоб напис "Меню" не залазив під годинник *@
    <MudDrawerHeader Style="padding-top: 45px;">
        @* 3. ЧОРНИЙ ТЕКСТ: Задаємо колір явно *@
        <MudText Typo="Typo.h6" Style="color: black; font-weight: bold;">Меню</MudText>
    </MudDrawerHeader>

    <MudNavMenu Bordered="true">
        @* 2. ЗАКРИТТЯ МЕНЮ: Додано OnClick="CloseDrawer" до кожного пункту
           3. ЧОРНИЙ ТЕКСТ: Додано Style="color: black;" до кожного пункту 
        *@
        <MudNavLink href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home"
                    OnClick="CloseDrawer">
            Головна
        </MudNavLink>

        <MudNavLink href="ukrains-railways" Icon="@Icons.Material.Filled.Map"
                    OnClick="CloseDrawer">
            Українська залізниця
        </MudNavLink>

        <MudNavLink href="trains" Icon="@Icons.Material.Filled.FormatListBulleted"
                    OnClick="CloseDrawer">
            Список поїздів
        </MudNavLink>

        <MudNavLink href="about" Icon="@Icons.Material.Filled.Info"
                    OnClick="CloseDrawer">
            Про нас
        </MudNavLink>

        <MudNavLink href="@YouTubeUrl" Target="_blank" Icon="@Icons.Custom.Brands.YouTube"
                    IconColor="Color.Error" OnClick="CloseDrawer">
            YouTube канал
        </MudNavLink>

        <MudDivider Class="my-2" />

        <AuthorizeView>
            <Authorized>
                <MudNavLink OnClick="Profile" Icon="@Icons.Material.Filled.Person" Style="color: black;">Профіль</MudNavLink>
                <MudNavLink OnClick="Logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error" Style="color: black;">Вийти</MudNavLink>
            </Authorized>
            <NotAuthorized>
                <MudNavLink OnClick="Login" Icon="@Icons.Material.Filled.Login" IconColor="Color.Primary" Style="color: black;">Вхід</MudNavLink>
                <MudNavLink OnClick="Register" Icon="@Icons.Material.Filled.PersonAdd" Style="color: black;">Реєстрація</MudNavLink>
            </NotAuthorized>
        </AuthorizeView>
    </MudNavMenu>
</MudDrawer>


@code {
    bool _drawerOpen = false;

    [Parameter] public string YouTubeUrl { get; set; } = "https://www.youtube.com/@RailwayUkraine";

    protected override void OnInitialized()
    {
        // Підписуємося на подію переходу між сторінками
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Якщо меню відкрите під час переходу — закриваємо його
        if (_drawerOpen)
        {
            _drawerOpen = false;
            StateHasChanged(); // Примусово кажемо UI оновитися
        }
    }

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    void CloseDrawer() => _drawerOpen = false;
    public void Dispose()
    {
        // Обов'язково відписуємося, щоб не було витоку пам'яті
        Nav.LocationChanged -= OnLocationChanged;
    }

    // Для кнопок авторизації (де немає href) просто міняємо статус
    private void Profile() { _drawerOpen = false; /* Навігація */ }
    private void Logout() { _drawerOpen = false; /* Логіка */ }
    private void Login() { _drawerOpen = false; /* Логіка */ }
    private void Register() { _drawerOpen = false; /* Логіка */ }
}