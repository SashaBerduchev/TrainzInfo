@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<div class="top-bar">
    <div class="top-bar-left">
        <button class="burger" @onclick="ToggleNavMenu">☰</button>
        <a class="brand" href="/" @onclick="CloseMenu">TrainzInfo</a>
    </div>

    <div class="top-bar-right">
        <img src="https://trainzinfo.com.ua/api/mainimage/getimage?name=MainPhoto"
             class="logo" />
    </div>
</div>

@if (!isNavCollapsed)
{
    <div class="menu-backdrop" @onclick="CloseMenu"></div>
}

<div class="side-menu @(isNavCollapsed ? "hidden" : "visible")">

    <nav class="menu d-flex flex-column">
        @* Додаємо @onclick="CloseMenu" до кожного NavLink *@
        <NavLink href="/" Match="NavLinkMatch.All" class="menu-link d-flex align-items-center" @onclick="CloseMenu">
            <i class="bi bi-house-door-fill me-3" style="font-size: 1.2rem;"></i>
            <span>Головна</span>
        </NavLink>

        <NavLink href="ukrains-railways" class="menu-link d-flex align-items-center" @onclick="CloseMenu">
            <i class="bi bi-train-lightrail-front-fill me-3" style="font-size: 1.2rem;"></i>
            <span>Українська залізниця</span>
        </NavLink>

        <NavLink href="trains" class="menu-link d-flex align-items-center" @onclick="CloseMenu">
            <i class="bi bi-card-list me-3" style="font-size: 1.2rem;"></i>
            <span>Список поїздів</span>
        </NavLink>

        <NavLink href="about" class="menu-link d-flex align-items-center" @onclick="CloseMenu">
            <i class="bi bi-train-front-fill me-3" style="font-size: 1.2rem;"></i>
            <span>Про нас</span>
        </NavLink>

        <NavLink href="@YouTubeUrl" target="_blank" class="menu-link d-flex align-items-center" @onclick="CloseMenu">
            <i class="bi bi-youtube me-3" style="font-size: 1.4rem; color: #FF0000; line-height: 1;"></i>
            <span>YouTube канал</span>
        </NavLink>
    </nav>

    <div class="auth-block">
        <AuthorizeView>
            <Authorized>
                <button class="btn light" @onclick="Profile">👤 Профіль</button>
                <button class="btn danger" @onclick="Logout">🚪 Вийти</button>
            </Authorized>

            <NotAuthorized>
                <button class="btn primary" @onclick="Login">🔐 Вхід</button>
                <button class="btn outline" @onclick="Register">➕ Реєстрація</button>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private string YouTubeUrl = "https://www.youtube.com/@RailwayUkraine";
    private bool isNavCollapsed = true;

    private void ToggleNavMenu() => isNavCollapsed = !isNavCollapsed;

    // Метод для примусового закриття
    private void CloseMenu() => isNavCollapsed = true;

    // Оновлені методи навігації (додано CloseMenu)
    private void Login() { CloseMenu(); Nav.NavigateTo("/login"); }
    private void Register() { CloseMenu(); Nav.NavigateTo("/register"); }
    private void Profile() { CloseMenu(); Nav.NavigateTo("/profile"); }
    private void Logout() { CloseMenu(); Nav.NavigateTo("/logout"); }
}