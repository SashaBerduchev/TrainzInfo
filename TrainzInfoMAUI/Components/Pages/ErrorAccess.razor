@page "/erroraccess"
@layout EmptyLayout

<div class="access-denied-container">
    <div class="content-card">
        <div class="icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" viewBox="0 0 16 16">
                <path d="M15 8a7 7 0 1 1-14 0 7 7 0 0 1 14 0zM5 8.5a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1H5z" />
            </svg>
        </div>

        <h1>Доступ обмежено</h1>
        <p>Схоже, у вас немає прав для перегляду цієї сторінки. Можливо, варто змінити "колію" або повернутися на головну.</p>

        <div class="actions">
            <a href="/" class="btn-primary">На головну</a>
            <button @onclick="GoBack" class="btn-secondary">Назад</button>
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void GoBack()
    {
        // Проста логіка повернення назад
        Navigation.NavigateTo("/");
    }
}