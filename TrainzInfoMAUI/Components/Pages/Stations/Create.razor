@page "/stations/create"
@using TrainzInfoShared.DTO.GetDTO
@inject NavigationManager Navigation
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mb-10">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl shadow-xl">

        <div class="text-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.House" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h4" Class="fw-bold">Нова станція</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Додавання об'єкта залізничної інфраструктури</MudText>
        </div>

        <EditForm Model="@stationsDTO" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />

            <MudStack Spacing="4">

                @* Назва станції *@
                <MudTextField Label="Назва станції" @bind-Value="stationsDTO.Name"
                              Variant="Variant.Outlined" Placeholder="Напр. Київ-Пасажирський"
                              Required="true" For="@(() => stationsDTO.Name)" />

                <MudGrid Spacing="2">
                    @* Область *@
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Область"
                                   Value="@stationsDTO.Oblasts"
                                   ValueChanged="OnOblastChanged"
                                   Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@("")">Оберіть область...</MudSelectItem>
                            @foreach (var item in OblastList)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Філія (Залізниця) *@
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Філія" @bind-Value="stationsDTO.UkrainsRailways"
                                   Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@("")">Оберіть філію...</MudSelectItem>
                            @foreach (var item in FiliasList)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                @* Місто - Автозаповнення *@
                <MudAutocomplete T="string" Label="Місто" @bind-Value="stationsDTO.Citys"
                                 SearchFunc="@SearchCity"
                                 Variant="Variant.Outlined"
                                 Placeholder="Почніть вводити місто..."
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true" CoerceValue="true"
                                 AdornmentIcon="@Icons.Material.Filled.LocationCity" AdornmentColor="Color.Primary" />

                @* Фото станції - Надійний метод *@
                <div class="d-flex flex-column gap-2">
                    <InputFile id="stationFileInput" OnChange="HandleFileSelected" style="display:none" />

                    <MudButton HtmlTag="label"
                               for="stationFileInput"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PhotoCamera"
                               FullWidth="true"
                               Class="py-3 rounded-lg border-2 border-dashed">
                        Завантажити фото станції
                    </MudButton>

                    @if (!string.IsNullOrEmpty(imagePreview))
                    {
                        <MudPaper Elevation="0" Class="pa-2 mud-bg-background-grey rounded-lg d-flex justify-center mt-2">
                            <MudImage Src="@imagePreview" Height="180" ObjectFit="ObjectFit.Contain" Class="rounded-lg shadow-sm" />
                        </MudPaper>
                    }
                </div>

                @* Помилки збереження *@
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="rounded-lg">
                        <strong>Помилка збереження:</strong> @ErrorMessage
                    </MudAlert>
                }

                @* Кнопка збереження *@
                <div class="d-flex justify-end mt-4">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Save"
                               Class="rounded-lg px-10 shadow-lg fw-bold">
                        Зберегти
                    </MudButton>
                </div>

            </MudStack>
        </EditForm>
    </MudPaper>
</MudContainer>



@code {
    private StationsDTO stationsDTO = new();
    private string city = "";
    private List<string> citys = new List<string>();
    private List<string> filteredCitys = new List<string>();
    private List<string> FiliasList = new List<string>();
    private List<string> OblastList = new List<string>();
    private CancellationTokenSource debounceCts;
    private string ErrorMessage = "";
    private string imagePreview;


    protected override async Task OnInitializedAsync()
    {
        // Імітація завантаження даних
        citys = await Http.GetFromJsonAsync<List<string>>($"api/stations/getcitys");
        FiliasList = await Http.GetFromJsonAsync<List<string>>($"api/stations/get-filias");
        OblastList = await Http.GetFromJsonAsync<List<string>>($"api/stations/get-oblasts");
    }

    private async Task HandleValidSubmit()
    {
        var response = await Http.PostAsJsonAsync("api/stations/create", stationsDTO);
        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/stations");
        }
        else
        {
            ErrorMessage = await response.Content.ReadAsStringAsync();
            // Обробка помилки
            Console.WriteLine("Помилка при створенні станції");
        }

        // Тут можна викликати API для збереження
        Console.WriteLine($"Станція: {stationsDTO.Name}, Місто: {city}, Філія: {stationsDTO.UkrainsRailways}");
    }

    private async Task OnOblastChanged(string value)
    {
        citys.Clear();
        stationsDTO.Oblasts = value;
        citys = await Http.GetFromJsonAsync<List<string>>($"api/stations/getcitys?oblast={value}");
    }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        city = e.Value?.ToString() ?? "";

        // скидаємо попередній debounce
        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        var token = debounceCts.Token;

        try
        {
            await Task.Delay(300, token); // debounce 300 мс

            if (!token.IsCancellationRequested)
            {
                if (string.IsNullOrWhiteSpace(city))
                {
                    filteredCitys.Clear();
                }
                else
                {
                    filteredCitys = citys
                        .Where(x => x.Contains(city, StringComparison.OrdinalIgnoreCase))
                        .Take(30)
                        .ToList();
                }
                StateHasChanged();
            }
        }
        catch (TaskCanceledException)
        {
            // нормально, просто перервано
        }
    }

    private async Task<IEnumerable<string>> SearchCity(string value, CancellationToken token)
    {
        var allCities = (citys ?? new List<string>()).Distinct();

        if (string.IsNullOrEmpty(value))
            return allCities;

        return allCities
            .Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private void SelectItem(string item)
    {
        city = item;
        stationsDTO.Citys = city;
        filteredCitys.Clear();
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB
        var buffer = new byte[file.Size];
        await stream.ReadAsync(buffer);

        imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";

        // Зберігаємо у модель для відправки на сервер
        stationsDTO.StationImages = imagePreview;
        stationsDTO.ImageMimeTypeOfData = file.ContentType;
    }

}
