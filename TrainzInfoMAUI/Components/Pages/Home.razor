@page "/"
@inject AppConfig Config
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>TrainzInfo</PageTitle>

<h1 class="display-4 text-center mb-4">Ласкаво просимо на сайт TrainzInfo!</h1>

<div class="text-center">
    <div class="maincardpage">
        <div class="main_text">
            Сайт ТреінзІнфо присвячено любителям залізничного транспорту...
        </div>

        <div class="btn_main_panel">
            <NavLink class="btn btn-info btn_news" href="/locomotives" style="width:160px; margin:10px;">Локомотиви</NavLink>
            <NavLink class="btn btn-info btn_news" href="/electric-trains" style="width:160px; margin:10px;">Електропоїзди</NavLink>
            <NavLink class="btn btn-info btn_news" href="/diesel-trains" style="width:160px; margin:10px;">Дизель-поїзди</NavLink>
            <NavLink class="btn btn-info btn_news" href="/stations" style="width:160px; margin:10px;">Станції</NavLink>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <input @bind="SearchText"
           @bind:event="oninput"
           type="text"
           class="form-control"
           placeholder="Пошук новин..."
           style="max-width:400px; margin:auto;" />
</div>

@*  Контейнер со списком новостей *@
<div class="mt-4" id="newsContainer">

    @if (allNews is null)
    {
        <p class="text-center text-muted">Завантаження…</p>
    }
    else if (!filteredNews.Any())
    {
        <div class="d-flex justify-content-center align-items-center"
             style="min-height: 60vh;">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var news in filteredNews)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="news-card-modern h-100 shadow-sm border-0">
                        @* Секція зображення з бейджем *@
                        <div class="news-img-container position-relative">
                            @if (!string.IsNullOrWhiteSpace(news.ImgSrc))
                            {
                                <img src="@(Config.ApiBaseUrl + news.ImgSrc)"
                                     alt="Новина"
                                     class="news-img" />
                            }
                            else
                            {
                                <div class="placeholder-news-img d-flex align-items-center justify-content-center">
                                    <i class="bi bi-newspaper text-muted fs-1"></i>
                                </div>
                            }
                            <div class="news-date-badge">
                                <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd.MM.yyyy") @* Тут можна підставити реальну дату *@
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            @* Заголовок новини *@
                            <h5 class="news-title mb-3">
                                @((MarkupString)news.NameNews)
                            </h5>

                            @* Короткий опис *@
                            <div class="news-excerpt flex-grow-1 mb-4">
                                @((MarkupString)news.BaseNewsInfo)
                            </div>

                            @* Кнопки дій *@
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                <NavLink href="@($"/news/details/{news.id}")" class="btn btn-main-sm">
                                    Читати далі <i class="bi bi-arrow-right ms-1"></i>
                                </NavLink>

                                @if (IsAdmin)
                                {
                                    <NavLink href="@($"/news/edit/{news.id}")" class="btn btn-outline-warning btn-sm border-0">
                                        <i class="bi bi-pencil-square"></i>
                                    </NavLink>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (isLoading)
        {
            <div class="d-flex justify-content-center align-items-center"
                 style="min-height: 60vh;">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        }
    }
</div>

@code {
    private List<NewsDTO> allNews = new();
    private List<NewsDTO> filteredNews = new();
    private string searchText = string.Empty;
    private bool IsAdmin = false;
    private int currentPage = 1;
    private bool isLoading = false;
    private bool allLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadNews();
        // Підписка на скрол через JS
        await JS.InvokeVoidAsync("addNewsScrollListener", DotNetObjectReference.Create(this));

        await JS.InvokeVoidAsync("showNewsContainer");
    }


    private async Task LoadNews()
    {
        if (isLoading || allLoaded) return;

        isLoading = true;

        try
        {
            var newItems = await Http.GetFromJsonAsync<List<NewsDTO>>($"api/news/getnews?page={currentPage}");
            if (newItems == null || newItems.Count == 0)
            {
                allLoaded = true;
            }
            else
            {
                allNews.AddRange(newItems);
                FilterNews(); // оновлюємо відфільтровані новини
                currentPage++;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Помилка завантаження новин: " + ex.Message);
        }
        await CheckRoles();
        isLoading = false;
        StateHasChanged();
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                IsAdmin = roles.Contains("Admin");
                IsAdmin = roles.Contains("Superadmin");
            }
            else
            {

            }
        }
    }

    private void FilterNews()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredNews = allNews.ToList();
        }
        else
        {
            filteredNews = allNews
                .Where(x => x.NameNews.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            FilterNews();
        }
    }

    [JSInvokable]
    public async Task OnScrollNearBottom()
    {
        await LoadNews();
    }
}