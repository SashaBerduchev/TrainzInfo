@page "/diesel-trains/details/{Id:int}"
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Дизель-поїзд @Title</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-10">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="fw-bold mb-6">@Title</MudText>

    @if (IsLoading)
    {
        <MudPaper Class="d-flex flex-column align-center justify-center py-12" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body1" Class="mt-4">Завантаження даних про дизель-поїзд...</MudText>
        </MudPaper>
    }
    else if (Error != null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@Error</MudAlert>
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Href="/diesel-trains">
            Назад до списку
        </MudButton>
    }
    else
    {
        <MudDivider Class="mb-6" />

        <MudCard Elevation="4" Class="mb-8 rounded-xl overflow-hidden">
            <MudGrid Spacing="0">
                <MudItem xs="12" md="5">
                    @if (dieselTrains.Image != null)
                    {
                        <MudImage Src="@dieselTrains.Image" Alt="Дизель-поїзд" Fluid="true"
                                  Class="object-cover h-100 w-100" Style="min-height: 350px;" />
                    }
                    else
                    {
                        <div class="d-flex align-center justify-center mud-bg-background-grey h-100" style="min-height: 350px;">
                            <MudIcon Icon="@Icons.Material.Filled.NoPhotography" Size="Size.Large" Color="Color.Default" />
                        </div>
                    }
                </MudItem>

                <MudItem xs="12" md="7" Class="pa-8">
                    <MudText Typo="Typo.h4" Color="Color.Primary" Class="fw-bold mb-2">
                        @dieselTrains.Name
                    </MudText>
                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Class="mb-6">№@dieselTrains.NumberTrain</MudChip>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Cabin" Color="Color.Info" />
                                <MudText><b>Депо:</b> @dieselTrains.DepotList</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.LocationCity" Color="Color.Info" />
                                <MudText><b>Місто:</b> @dieselTrains.City</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Info" />
                                <MudText><b>Філія:</b> @dieselTrains.Filia</MudText>
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-6" />
                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="line-height: 1.7;">
                        @dieselTrains.BaseInfo
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudCard>

        @if (dieselTrains.Station != null)
        {
            <MudText Typo="Typo.h5" Class="mb-4 ml-2">Прив'язка до станції</MudText>
            <MudCard Elevation="2" Class="mb-8 rounded-lg border-l-4 mud-border-warning">
                <MudGrid Spacing="0">
                    <MudItem xs="12" md="4">
                        @if (!string.IsNullOrEmpty(dieselTrains.StationImages))
                        {
                            <MudImage Src="@dieselTrains.StationImages" Alt="@dieselTrains.Station"
                                      Fluid="true" Class="h-100 object-cover" />
                        }
                        else
                        {
                            <div class="pa-8 d-flex flex-column align-center justify-center mud-bg-background-grey">
                                <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Default" Size="Size.Large" />
                                <MudText Typo="Typo.caption">Немає фото станції</MudText>
                            </div>
                        }
                    </MudItem>
                    <MudItem xs="12" md="8" Class="pa-6">
                        <MudText Typo="Typo.h5" Color="Color.Warning" Class="mb-2">@dieselTrains.Station</MudText>
                        <MudText Typo="Typo.body1">
                            Цей дизель-поїзд обслуговує маршрути, що проходять через станцію @dieselTrains.Station.
                        </MudText>
                    </MudItem>
                </MudGrid>
            </MudCard>
        }

        <MudPaper Elevation="1" Class="pa-6 mb-8 rounded-lg bg-lighten-5">
            <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">Повна інформація</MudText>
            <MudText Typo="Typo.body1" Style="white-space: pre-line;">@dieselTrains.AllInfo</MudText>
        </MudPaper>

        @if (IsPublisherOrAdmin || IsSuperadmin)
        {
            <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Class="mb-8 pa-4 rounded-xl">
                <MudText Typo="Typo.subtitle1" Class="fw-bold mb-3">Інструменти редагування</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                    @if (IsPublisherOrAdmin)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.NoteAdd"
                                   Href="@($"/edit-info/{dieselTrains.Id}")" Target="_blank">
                            Додаткова інфо
                        </MudButton>
                    }
                    @if (IsSuperadmin)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Edit"
                                   Href="@($"/locomotive/edit/{dieselTrains.Id}")">Основні дані</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddPhotoAlternate"
                                   Href="@($"/locomotive/add-image/{dieselTrains.Id}")">Зображення</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever"
                                   OnClick="DeleteDiesel">Видалити</MudButton>
                    }
                </MudStack>
            </MudAlert>
        }

        @if (ErrorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6">
                <strong>Помилка:</strong> @ErrorMessage
            </MudAlert>
        }

        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/diesel-trains" Class="mb-10">
            Повернутися до дизель-поїздів
        </MudButton>
    }
</MudContainer>


@code {
    [Parameter] public int Id { get; set; }

    private DieselTrainsDTO? dieselTrains;
    private string? ErrorMessage;
    private bool IsPublisherOrAdmin = false;
    private bool IsSuperadmin = false;
    private string Title = "Дизель-поїзд";
    private bool IsLoading = true; 
    private string? Error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IsLoading = true;

            // Авторизація
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;

            IsPublisherOrAdmin =
                user.IsInRole("Publisher") ||
                user.IsInRole("Admin") ||
                user.IsInRole("Superadmin");

            IsSuperadmin = user.IsInRole("Superadmin");

            // Завантажуємо локомотив
            dieselTrains = await Http.GetFromJsonAsync<DieselTrainsDTO>($"api/diesels/details/{Id}");

            if (dieselTrains == null)
            {
                Error = "Дизель не знайдено.";
                return;
            }

            Title = $"{dieselTrains.Name} - {dieselTrains.NumberTrain}";


        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

     

    private async Task DeleteDiesel()
    {
        if (!await Confirm("Ви впевнені що хочете видалити дизель-поїзд?"))
            return;
        var response = await Http.DeleteAsync($"api/diesels/deleteapprove/{Id}");
        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/diesel-trains");
        else
            ErrorMessage = "Помилка видалення: " + await response.Content.ReadAsStringAsync();
    }

    private async Task<bool> Confirm(string message)
    {
        return await Task.FromResult(await JS.InvokeAsync<bool>("confirm", message));
    }
}
