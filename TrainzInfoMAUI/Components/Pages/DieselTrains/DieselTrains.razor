@page "/diesel-trains"
@using System.Threading.Tasks
@using SharedDTO.DTO.GetDTO
@inject HttpClient Http
@inject NavigationManager Nav;
@inject AuthenticationStateProvider AuthStateProvider
@inject AppConfig Config
@inject IJSRuntime JS

<PageTitle>Дизель-поїзди</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-10">
    <MudText Typo="Typo.h3" Align="Align.Center" Color="Color.Primary" Class="fw-bold mb-6">Дизель-поїзди</MudText>

    @if (IsPublisherOrAdminOrSuperAdmin)
    {
        <MudPaper Elevation="2" Class="pa-4 mb-6 mud-theme-dark rounded-lg">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateDieselTrain">
                    Створити
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Refresh" OnClick="UpdateData">
                    Оновити дані
                </MudButton>
            </MudStack>
        </MudPaper>
    }

    <MudPaper Elevation="3" Class="pa-6 mb-8 rounded-xl">
        <MudGrid Spacing="3" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Філія" Value="@selectedFilia" ValueChanged="@(v => OnFiliaChanged(v))" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem Value="@("")">Всі філії</MudSelectItem>
                    @foreach (var f in filias)
                    {
                        <MudSelectItem Value="@f">@f</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Область" Value="@selectedOblast" ValueChanged="@(v => OnOblastChanged(v))" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem Value="@("")">Всі області</MudSelectItem>
                    @foreach (var o in oblasts)
                    {
                        <MudSelectItem Value="@o">@o</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="string" Label="Депо" Value="@selectedDepo" ValueChanged="@(v => OnDepoChanged(v))" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem Value="@("")">Всі депо</MudSelectItem>
                    @foreach (var d in depos)
                    {
                        <MudSelectItem Value="@d">@d</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="string" Label="Модель" Value="@selectedModel" ValueChanged="@(v => OnModelChanged(v))" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem Value="@("")">Всі моделі</MudSelectItem>
                    @foreach (var m in models)
                    {
                        <MudSelectItem Value="@m">@m</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.FilterAltOff"
                           OnClick="ClearFilter" FullWidth="true" Size="Size.Medium">
                    Скинути
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (loading == false || !dieselTrains.Any())
    {
        <MudGrid Spacing="6">
            @foreach (var i in Enumerable.Range(0, 3))
            {
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4 rounded-xl">
                        <MudGrid Spacing="0">
                            <MudItem xs="12" md="4">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12" md="8" Class="pa-6">
                                <MudSkeleton Width="50%" Height="42px" Class="mb-4" />
                                <MudSkeleton Width="100%" />
                                <MudSkeleton Width="100%" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <div id="dieselContainer">
            @foreach (var item in dieselTrains)
            {
                <MudPaper Elevation="4" Class="mb-6 overflow-hidden rounded-xl loco-card-hover train-card-animate">
                    <MudGrid Spacing="0">
                        <MudItem xs="12" md="4">
                            <MudImage Src="@(Config.ApiBaseUrl + item.Image)" Alt="Дизель-поїзд"
                                      ObjectFit="ObjectFit.Cover" Height="220" Class="w-100" />
                        </MudItem>

                        <MudItem xs="12" md="5" Class="pa-6">
                            <div class="d-flex align-center mb-4">
                                <MudText Typo="Typo.h4" Color="Color.Primary" Class="fw-bold">@item.Name</MudText>
                                <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary" Class="ml-2 fw-bold">№@item.NumberTrain</MudChip>
                            </div>

                            <MudGrid Spacing="1">
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Депо</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-medium">@item.DepotList</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Філія</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-medium">@item.Filia</MudText>
                                </MudItem>
                                <MudItem xs="12" Class="mt-2">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="Color.Error" />
                                        <MudText Typo="Typo.body1">
                                            <b class="mud-text-primary">@item.Station</b> (@item.Oblast, @item.City)
                                        </MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudItem>

                        <MudItem xs="12" md="3" Class="pa-4 mud-bg-background-grey d-flex flex-column justify-center gap-3 border-l-md">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Info" Href="@($"/diesel-trains/details/{item.Id}")" FullWidth="true">
                                Детально
                            </MudButton>

                            @if (currentUser != null && (currentUser.Role == "Publisher" || currentUser.Role == "Admin" || currentUser.Role == "Superadmin"))
                            {
                                <MudDivider Class="my-1" />
                                <MudStack Spacing="1">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.AddAPhoto" Href="@($"/diesel-trains/add-image/{item.Id}")" FullWidth="true">
                                        Фото
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Edit" Href="@($"/diesel-trains/edit/{item.Id}")" FullWidth="true">
                                        Редагувати
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Delete" OnClick="() => DeleteTrain(item.Id)" FullWidth="true">
                                        Видалити
                                    </MudButton>
                                </MudStack>
                            }
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }
        </div>
    }
</MudContainer>

<style>
    
</style>

@code {
    private List<DieselTrainsDTO> dieselTrains = new();
    private List<DieselTrainsDTO> filteredTrains = new();
    private UserDto currentUser;
    private bool IsPublisherOrAdminOrSuperAdmin;
    private bool isFilterLoad = false;

    private string selectedFilia { get; set; } = "";
    private string selectedOblast { get; set; } = "";
    private string selectedDepo { get; set; } = "";
    private string selectedModel { get; set; } = "";

    private List<string> filias = new();
    private List<string> oblasts = new();
    private List<string> depos = new();
    private List<string> models = new();
    private UserDto CurrentUser { get; set; }

    private bool loading = false;

    private int currentPage = 1;
    private bool isLoading = false;
    private bool allLoaded = false;
    [Parameter]
    [SupplyParameterFromQuery(Name = "depotsName")]
    public string? DepotNameFromQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await CheckRoles();
        await Load();

        filteredTrains = dieselTrains.ToList();



        // JS для анімації
        await JS.InvokeVoidAsync("addDieselsScrollListener", DotNetObjectReference.Create(this));
    }

    public async Task Load()
    {
        if (isLoading || allLoaded) return;

        if (DepotNameFromQuery is not null)
        {
            selectedDepo = DepotNameFromQuery;
        }

        isLoading = true;
        var url =
               $"api/diesels/gettrains?page={currentPage}" +
               $"{(string.IsNullOrWhiteSpace(selectedFilia) ? "" : $"&filia={Uri.EscapeDataString(selectedFilia)}")}" +
               $"{(string.IsNullOrWhiteSpace(selectedDepo) ? "" : $"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
               $"{(string.IsNullOrWhiteSpace(selectedModel) ? "" : $"&model={Uri.EscapeDataString(selectedModel)}")}" +
               $"{(string.IsNullOrWhiteSpace(selectedOblast) ? "" : $"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
        var dieselPage = await Http.GetFromJsonAsync<List<DieselTrainsDTO>>(url);
        if (dieselPage == null || dieselPage.Count == 0)
        {
            allLoaded = true;
        }
        else
        {
            dieselTrains.AddRange(dieselPage);
            //    await ApplyFilter(); // Оновлюємо відфільтровані по фільтрах

            if (!isFilterLoad)
            {
                var urlfilia = $"api/diesels/filias{($"?filia={Uri.EscapeDataString(selectedFilia)}")}"+
                 $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}"+
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                var urldepo = $"api/diesels/depos{($"?filia={Uri.EscapeDataString(selectedFilia)}")}" +
                $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                var urlmodel = $"api/diesels/models{($"?filia={Uri.EscapeDataString(selectedFilia)}")}" +
                 $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                var urloblast = $"api/diesels/oblasts{($"?filia={Uri.EscapeDataString(selectedFilia)}")}" +
                $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                filias = await Http.GetFromJsonAsync<List<string>>(urlfilia);
                oblasts = await Http.GetFromJsonAsync<List<string>>(urloblast);
                depos = await Http.GetFromJsonAsync<List<string>>(urldepo);
                models = await Http.GetFromJsonAsync<List<string>>(urlmodel);
                isFilterLoad = true;
            }
            currentPage++;

        }
        loading = true;
        isLoading = false;
        StateHasChanged();
    }

    private async Task OnFiliaChanged(string value)
    {
        selectedFilia = value ?? "";
        await ApplyFilter();
    }

    private async Task OnOblastChanged(string value)
    {
        selectedOblast = value ?? "";
        await ApplyFilter();
    }

    private async Task OnDepoChanged(string value)
    {
        selectedDepo = value ?? "";
        await ApplyFilter();
    }

    private async Task OnModelChanged(string value)
    {
        selectedModel = value ?? "";
        await ApplyFilter();
    }

    private async Task ApplyFilter()
    {
        currentPage = 1;
        allLoaded = false;
        dieselTrains.Clear();          // если хотите начать с нуля
        isFilterLoad = false;
        models.Clear();
        filias.Clear();
        depos.Clear();
        oblasts.Clear();
        await Load();                 // загружаем первую страницу
        await JS.InvokeVoidAsync("revealNewDieselCards");

    }

    private async Task ClearFilter()
    {
        selectedFilia = selectedOblast = selectedDepo = selectedModel = "";
        currentPage = 1;
        allLoaded = false;
        dieselTrains.Clear();          // если хотите начать с нуля
        isFilterLoad = false;
        models.Clear();
        filias.Clear();
        depos.Clear();
        oblasts.Clear();
        await Load();                 // загружаем первую страницу
        await JS.InvokeVoidAsync("revealNewDieselCards");
    }

    private void CreateDieselTrain()
    {
        // Навігація на створення
        Nav.NavigateTo("/diesel-trains/create");
    }

    private void DeleteTrain(int id)
    {
        // Виклик API на видалення
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                IsPublisherOrAdminOrSuperAdmin = roles.Contains("Admin");
                IsPublisherOrAdminOrSuperAdmin = roles.Contains("Superadmin");

            }
            else
            {

            }
        }
    }


    private async Task UpdateData()
    {
        var response = Http.GetStringAsync("api/diesels/update");
        Console.WriteLine(response);
        Nav.NavigateTo("/diesel-trains");
    }

    [JSInvokable]
    public async Task OnScrollNearBottom()
    {
        await Load();
    }

}
