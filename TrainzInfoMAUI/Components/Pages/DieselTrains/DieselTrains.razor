@page "/diesel-trains"
@using System.Threading.Tasks
@using TrainzInfoShared.DTO.GetDTO
@inject HttpClient Http
@inject NavigationManager Nav;
@inject AuthenticationStateProvider AuthStateProvider
@inject AppConfig Config
@inject IJSRuntime JS

<h1 class="mb-4 text-center">Дизель-поїзди</h1>

@if (IsPublisherOrAdminOrSuperAdmin)
{
    <button class="btn btn-info mb-3" @onclick="CreateDieselTrain">Створити</button>
    <button class="btn btn-info mb-2" @onclick="@UpdateData">Оновити дані</button>
}

<div class="row g-2 mb-3">
    <div class="col-12 col-md-3">
        <select class="form-control" @bind="selectedFilia">
            <option value="">Всі філії</option>
            @foreach (var f in filias)
            {
                <option value="@f">@f</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <select class="form-control" @bind="selectedOblast">
            <option value="">Всі області</option>
            @foreach (var o in oblasts)
            {
                <option value="@o">@o</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <select class="form-control" @bind="selectedDepo">
            <option value="">Всі депо</option>
            @foreach (var d in depos)
            {
                <option value="@d">@d</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <select class="form-control" @bind="selectedModel">
            <option value="">Всі моделі</option>
            @foreach (var m in models)
            {
                <option value="@m">@m</option>
            }
        </select>
    </div>
    <div class="col-12 mt-2">
        <button class="btn btn-info w-100" @onclick="ApplyFilter">Відобразити</button>
    </div>
</div>

<button class="btn btn-secondary mb-3" @onclick="ClearFilter">Скинути фільтр</button>

<div class="row" id="dieselContainer">
    @if (loading == false)
    {
        <div class="d-flex justify-content-center align-items-center"
             style="min-height: 60vh;">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!dieselTrains.Any())
    {
        <div class="d-flex justify-content-center align-items-center"
             style="min-height: 60vh;">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        @foreach (var item in dieselTrains)
        {
            <div class="col-12 mb-4">
                <div class="loco-card-modern shadow-sm border-0">
                    <div class="row g-0">
                        <div class="col-12 col-md-4 position-relative overflow-hidden">
                            <img class="loco-img"
                                 src="@(Config.ApiBaseUrl + item.Image)"
                                 alt="Дизель-поїзд @item.Name" />
                            @* Якщо в моделі дизелів з'явиться швидкість, можна додати speed-badge тут *@
                        </div>

                        <div class="col-12 col-md-5 p-4 border-end-md">
                            <div class="d-flex align-items-center mb-2">
                                <h3 class="loco-title mb-0">@item.Name</h3>
                                <span class="loco-number ms-2">№@item.NumberTrain</span>
                            </div>

                            <div class="info-grid">
                                <div class="info-item">
                                    <span class="label">Депо</span>
                                    <span class="value">@item.DepotList</span>
                                </div>
                                <div class="info-item">
                                    <span class="label">Філія</span>
                                    <span class="value">@item.Filia</span>
                                </div>
                                <div class="info-item">
                                    <span class="label">Локація</span>
                                    <span class="value">@item.Oblast, @item.City</span>
                                </div>
                                <div class="info-item">
                                    <span class="label">Станція</span>
                                    <span class="value station-highlight">@item.Station</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-3 bg-light-subtle d-flex flex-column justify-content-center p-3 gap-2">
                            <NavLink class="btn btn-main" href="@($"/diesel-trains/details/{item.Id}")">
                                <i class="bi bi-info-circle"></i> Детально
                            </NavLink>

                            @if (currentUser != null && (currentUser.Role == "Publisher" || currentUser.Role == "Admin" || currentUser.Role == "Superadmin"))
                            {
                                <div class="admin-actions mt-2 pt-2 border-top">
                                    <div class="d-flex flex-column gap-2">
                                        <NavLink class="btn btn-sm btn-outline-warning w-100" href="@($"/diesel-trains/add-image/{item.Id}")">
                                            <i class="bi bi-image"></i> Додати фото
                                        </NavLink>
                                        <NavLink class="btn btn-sm btn-outline-primary w-100" href="@($"/diesel-trains/edit/{item.Id}")">
                                            <i class="bi bi-pencil"></i> Редагувати
                                        </NavLink>
                                        <button class="btn btn-sm btn-outline-danger w-100" @onclick="() => DeleteTrain(item.Id)">
                                            <i class="bi bi-trash"></i> Видалити
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<DieselTrainsDTO> dieselTrains = new();
    private List<DieselTrainsDTO> filteredTrains = new();
    private UserDto currentUser;
    private bool IsPublisherOrAdminOrSuperAdmin;
    private bool isFilterLoad = false;

    private string selectedFilia { get; set; } = "";
    private string selectedOblast { get; set; } = "";
    private string selectedDepo { get; set; } = "";
    private string selectedModel { get; set; } = "";

    private List<string> filias = new();
    private List<string> oblasts = new();
    private List<string> depos = new();
    private List<string> models = new();
    private UserDto CurrentUser { get; set; }

    private bool loading = false;

    private int currentPage = 1;
    private bool isLoading = false;
    private bool allLoaded = false;
    [Parameter]
    [SupplyParameterFromQuery(Name = "depotsName")]
    public string? DepotNameFromQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await CheckRoles();
        await Load();

        filteredTrains = dieselTrains.ToList();



        // JS для анімації
        await JS.InvokeVoidAsync("addDieselsScrollListener", DotNetObjectReference.Create(this));
    }

    public async Task Load()
    {
        if (isLoading || allLoaded) return;

        if (DepotNameFromQuery is not null)
        {
            selectedDepo = DepotNameFromQuery;
        }

        isLoading = true;
        var url =
               $"api/diesels/gettrains?page={currentPage}" +
               $"{(string.IsNullOrWhiteSpace(selectedFilia) ? "" : $"&filia={Uri.EscapeDataString(selectedFilia)}")}" +
               $"{(string.IsNullOrWhiteSpace(selectedDepo) ? "" : $"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
               $"{(string.IsNullOrWhiteSpace(selectedModel) ? "" : $"&model={Uri.EscapeDataString(selectedModel)}")}" +
               $"{(string.IsNullOrWhiteSpace(selectedOblast) ? "" : $"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
        var dieselPage = await Http.GetFromJsonAsync<List<DieselTrainsDTO>>(url);
        if (dieselPage == null || dieselPage.Count == 0)
        {
            allLoaded = true;
        }
        else
        {
            dieselTrains.AddRange(dieselPage);
            //    await ApplyFilter(); // Оновлюємо відфільтровані по фільтрах

            if (!isFilterLoad)
            {
                var urlfilia = $"api/diesels/filias{($"?filia={Uri.EscapeDataString(selectedFilia)}")}"+
                 $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}"+
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                var urldepo = $"api/diesels/depos{($"?filia={Uri.EscapeDataString(selectedFilia)}")}" +
                $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                var urlmodel = $"api/diesels/models{($"?filia={Uri.EscapeDataString(selectedFilia)}")}" +
                 $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                var urloblast = $"api/diesels/oblasts{($"?filia={Uri.EscapeDataString(selectedFilia)}")}" +
                $"{($"&depot={Uri.EscapeDataString(selectedDepo)}")}" +
                 $"{($"&model={Uri.EscapeDataString(selectedModel)}")}" +
                 $"{($"&oblast={Uri.EscapeDataString(selectedOblast)}")}";
                filias = await Http.GetFromJsonAsync<List<string>>(urlfilia);
                oblasts = await Http.GetFromJsonAsync<List<string>>(urloblast);
                depos = await Http.GetFromJsonAsync<List<string>>(urldepo);
                models = await Http.GetFromJsonAsync<List<string>>(urlmodel);
                isFilterLoad = true;
            }
            currentPage++;

        }
        loading = true;
        isLoading = false;
        StateHasChanged();
    }
    private async Task ApplyFilter()
    {
        currentPage = 1;
        allLoaded = false;
        dieselTrains.Clear();          // если хотите начать с нуля
        isFilterLoad = false;
        models.Clear();
        filias.Clear();
        depos.Clear();
        oblasts.Clear();
        await Load();                 // загружаем первую страницу
        await JS.InvokeVoidAsync("revealNewDieselCards");

    }

    private async Task ClearFilter()
    {
        selectedFilia = selectedOblast = selectedDepo = selectedModel = "";
        currentPage = 1;
        allLoaded = false;
        dieselTrains.Clear();          // если хотите начать с нуля
        isFilterLoad = false;
        models.Clear();
        filias.Clear();
        depos.Clear();
        oblasts.Clear();
        await Load();                 // загружаем первую страницу
        await JS.InvokeVoidAsync("revealNewDieselCards");
    }

    private void CreateDieselTrain()
    {
        // Навігація на створення
        Nav.NavigateTo("/diesel-trains/create");
    }

    private void DeleteTrain(int id)
    {
        // Виклик API на видалення
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                IsPublisherOrAdminOrSuperAdmin = roles.Contains("Admin");
                IsPublisherOrAdminOrSuperAdmin = roles.Contains("Superadmin");

            }
            else
            {

            }
        }
    }


    private async Task UpdateData()
    {
        var response = Http.GetStringAsync("api/diesels/update");
        Console.WriteLine(response);
        Nav.NavigateTo("/diesel-trains");
    }

    [JSInvokable]
    public async Task OnScrollNearBottom()
    {
        await Load();
    }

}
