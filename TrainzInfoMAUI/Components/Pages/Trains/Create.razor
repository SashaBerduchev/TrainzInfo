@page "/trains/create"
@using SharedDTO.DTO.GetDTO
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl">
        <MudText Typo="Typo.h4" Class="fw-bold mb-6 text-center" Color="Color.Primary">
            <MudIcon Icon="@Icons.Material.Filled.Train" Size="Size.Large" Class="mr-2" />
            Створити поїзд
        </MudText>

        <EditForm Model="@trainDTO" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            
            <MudStack Spacing="4">
                
                @* Номер поїзда *@
                <MudNumericField Label="Номер поїзда"
                                 @bind-Value="trainDTO.Number"
                                 Variant="Variant.Outlined"
                                 For="@(() => trainDTO.Number)"
                                 HideSpinButtons="false" />

                @* Станція відправлення - Autocomplete *@
                <MudAutocomplete T="string" Label="Станція відправлення"
                                 @bind-Value="trainDTO.StationFrom"
                                 SearchFunc="@SearchStations"
                                 Variant="Variant.Outlined"
                                 Placeholder="Почніть вводити станцію..."
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true" CoerceValue="true"
                                 AdornmentIcon="@Icons.Material.Filled.DepartureBoard"
                                 AdornmentColor="Color.Primary"
                                 For="@(() => trainDTO.StationFrom)" />

                @* Станція прибуття - Autocomplete *@
                <MudAutocomplete T="string" Label="Станція прибуття"
                                 @bind-Value="trainDTO.StationTo"
                                 SearchFunc="@SearchStations"
                                 Variant="Variant.Outlined"
                                 Placeholder="Почніть вводити станцію..."
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true" CoerceValue="true"
                                 AdornmentIcon="@Icons.Material.Filled.Adb"
                                 AdornmentColor="Color.Secondary"
                                 For="@(() => trainDTO.StationTo)" />

                @* Тип поїзда *@
                <MudSelect T="string" Label="Тип поїзда"
                           @bind-Value="trainDTO.PassTrainType"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           For="@(() => trainDTO.PassTrainType)">
                    @foreach (var item in TypesList)
                    {
                        <MudSelectItem Value="@item">@item</MudSelectItem>
                    }
                </MudSelect>

                @* Назва поїзда *@
                <MudTextField Label="Назва поїзда (якщо фірмовий)"
                              @bind-Value="trainDTO.NameOfTrain"
                              Variant="Variant.Outlined"
                              Placeholder="Напр. Оберіг"
                              For="@(() => trainDTO.NameOfTrain)" />

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="rounded-lg mt-2">
                        Помилка збереження: @ErrorMessage
                    </MudAlert>
                }

                @* Кнопка дії *@
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Add"
                           Class="mt-4 rounded-lg py-3 fw-bold shadow-lg">
                    Створити поїзд
                </MudButton>

            </MudStack>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private string ErrorMessage = "";
    private TrainDTO trainDTO = new TrainDTO();
    private List<string> filterstationsTo = new List<string>();
    private List<string> stations = new List<string>();
    private List<string> filterstationsFrom = new List<string>();
    private CancellationTokenSource debounceCts;
    private string stationFrom = "";
    private string stationTo = "";
    private List<string> TypesList = new List<string>();


    protected override async Task OnInitializedAsync()
    {
        stations = await Http.GetFromJsonAsync<List<string>>($"api/stations/getnamesstations");
        TypesList.Add("");
        TypesList.AddRange(await Http.GetFromJsonAsync<List<string>>($"api/trains/gettypes"));
    }


    private async Task<IEnumerable<string>> SearchStations(string value, CancellationToken token)
    {
        // Якщо пусто — нічого не показуємо, або повертаємо весь список
        if (string.IsNullOrEmpty(value))
            return new string[0];

        // Тут має бути виклик твого сервісу або фільтрація списку
        // Наприклад: return StationsList.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
        return stations.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task OnInputChangedStationFrom(ChangeEventArgs e)
    {
        stationFrom = e.Value?.ToString() ?? "";

        // скидаємо попередній debounce
        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        var token = debounceCts.Token;

        try
        {
            await Task.Delay(200, token); // debounce 300 мс

            if (!token.IsCancellationRequested)
            {
                if (string.IsNullOrWhiteSpace(stationFrom))
                {
                    filterstationsFrom.Clear();
                }
                else
                {
                    filterstationsFrom = stations
                        .Where(x => x.Contains(stationFrom, StringComparison.OrdinalIgnoreCase))
                        .Take(7)
                        .ToList();
                }
                StateHasChanged();
            }
        }
        catch (TaskCanceledException)
        {
            // нормально, просто перервано
        }
    }

    private async Task HandleValidSubmit()
    {
        await CheckRoles();
        var result = await Http.PostAsJsonAsync("api/trains/create", trainDTO);
        if (!result.IsSuccessStatusCode)
        {
            ErrorMessage = await result.Content.ReadAsStringAsync();
        }
        else
        {
            Navigation.NavigateTo("/trains");
        }
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();

                trainDTO.username = email;

            }
            else
            {

            }
        }
    }

    private async Task OnInputChangedStationTo(ChangeEventArgs e)
    {
        stationTo = e.Value?.ToString() ?? "";

        // скидаємо попередній debounce
        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        var token = debounceCts.Token;

        try
        {
            await Task.Delay(200, token); // debounce 300 мс

            if (!token.IsCancellationRequested)
            {
                if (string.IsNullOrWhiteSpace(stationTo))
                {
                    filterstationsTo.Clear();
                }
                else
                {
                    filterstationsTo = stations
                        .Where(x => x.Contains(stationTo, StringComparison.OrdinalIgnoreCase))
                        .Take(7)
                        .ToList();
                }
                StateHasChanged();
            }
        }
        catch (TaskCanceledException)
        {
            // нормально, просто перервано
        }
    }

    private void SelectStationsFrom(string item)
    {
        stationFrom = item;
        trainDTO.StationFrom = stationFrom;
        filterstationsFrom.Clear();
    }

    private void SelectStationsTo(string item)
    {
        stationTo = item;
        trainDTO.StationTo = stationTo;
        filterstationsTo.Clear();
    }
}

