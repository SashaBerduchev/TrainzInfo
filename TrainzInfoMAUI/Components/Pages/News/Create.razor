@page "/news/create"
@using SharedDTO.DTO.GetDTO
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<h4>Новини</h4>
<hr />

@if (isLoading || !isEditorsReady)
{
    <div class="d-flex justify-center align-center" style="min-height: 60vh;">
        <MudStack AlignItems="AlignItems.Center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">Налаштовуємо редактори...</MudText>
        </MudStack>
    </div>
}

@* Ховаємо форму, поки QuillJS не відрендериться *@
<div style="@(isEditorsReady ? "display: block;" : "visibility: hidden; position: absolute; left: -9999px;")">
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-10">
        <MudPaper Elevation="4" Class="pa-8 rounded-xl shadow-xl">

            <div class="text-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.Newspaper" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h4" Class="fw-bold">Створення новини</MudText>
                @if (!string.IsNullOrEmpty(number) && number != "0")
                {
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">ID Новини: @number</MudText>
                }
            </div>

            <EditForm Model="@news" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <MudStack Spacing="4">

                    @* Назва новини *@
                    <div class="mud-input-control mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1 mb-1 d-block">Назва новини</MudText>
                        <MudPaper Elevation="0" Outlined="true" Class="pa-1">
                            <MudExRichTextEdit @bind-Value="news.NameNews" Height="150" />
                        </MudPaper>
                    </div>

                    @* Короткий опис *@
                    <div class="mud-input-control mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1 mb-1 d-block">Короткий опис</MudText>
                        <MudPaper Elevation="0" Outlined="true" Class="pa-1">
                            <MudExRichTextEdit @bind-Value="news.BaseNewsInfo" Height="150" />
                        </MudPaper>
                    </div>

                    @* Повний текст новини *@
                    <div class="mud-input-control mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1 mb-1 d-block">Повний текст новини</MudText>
                        <MudPaper Elevation="0" Outlined="true" Class="pa-1">
                            <MudExRichTextEdit @bind-Value="news.NewsInfoAll" Height="300" />
                        </MudPaper>
                    </div>

                    <MudGrid Spacing="2">
                        @* Посилання *@
                        <MudItem xs="12" md="6">
                            @* Додав Lines="3", щоб було зручно вводити кілька посилань, як ми робили на минулій сторінці *@
                            <MudTextField Label="Посилання на першоджерело" @bind-Value="news.LinkSorce"
                                          Variant="Variant.Outlined" Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Link" Lines="3" />
                        </MudItem>

                        @* Дата *@
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Дата актуалізації" @bind-Date="DateAdapter" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>

                    @* Фото новини *@
                    <div class="d-flex flex-column gap-2 mt-2">
                        <InputFile id="newsFileInput" OnChange="HandleFileSelected" style="display:none" accept="image/*" />

                        <MudButton HtmlTag="label"
                                   for="newsFileInput"
                                   Variant="Variant.Outlined"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Image"
                                   FullWidth="true"
                                   Class="py-3 rounded-lg border-2 border-dashed">
                            Вибрати головне зображення
                        </MudButton>

                        @if (!string.IsNullOrEmpty(imagePreview))
                        {
                            <MudPaper Elevation="0" Class="pa-2 mud-bg-background-grey rounded-lg d-flex justify-center mt-2">
                                <MudImage Src="@imagePreview" Height="200" ObjectFit="ObjectFit.Contain" Class="rounded-lg shadow-sm" />
                            </MudPaper>
                        }
                    </div>

                    @* Кнопки дій *@
                    <div class="d-flex justify-end gap-4 mt-6">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   OnClick="@(() => submitAction = "apply")"
                                   Class="rounded-lg px-8">
                            Застосувати
                        </MudButton>

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="@(() => submitAction = "ok")"
                                   Class="rounded-lg px-10 shadow-lg fw-bold">
                            Опублікувати
                        </MudButton>
                    </div>

                </MudStack>
            </EditForm>
        </MudPaper>
    </MudContainer>
</div>
@if (!string.IsNullOrEmpty(errors))
{
    <div class="alert alert-danger mt-3">
        <h5>Помилка збереження:</h5>
        <p>@errors</p>
    </div>
}
@if (isSave)
{
    <div class="alert alert-warning mt-3">
        <h5>Збереження...</h5>
    </div>
}


@code {
    private NewsSetDTO news = new NewsSetDTO();
    private string imagePreview;
    private string number;
    private string submitAction = "";
    private bool isLoading = false;
    private bool isEditorsReady = false;
    private bool isSave = false;
    private string errors;

    protected override Task OnInitializedAsync()
    {
        news.DateEndActual = DateOnly.FromDateTime(DateTime.UtcNow);
        news.NameNews = string.Empty;
        news.BaseNewsInfo = string.Empty;
        news.NewsInfoAll = string.Empty;
        news.LinkSorce = string.Empty;
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(1500); // Даємо QuillJS час побудувати панелі
            isEditorsReady = true;
            StateHasChanged(); // Кажемо Blazor прибрати спінер
        }
    }


    private DateTime? DateAdapter
    {
        get
        {
            // Тепер оператор '?' спрацює, бо DateEndActual став nullable
            return news.DateEndActual?.ToDateTime(TimeOnly.MinValue);
        }
        set
        {
            // Спокійно присвоюємо null, якщо дата не вибрана
            news.DateEndActual = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
        }
    }


    private async Task HandleValidSubmit()
    {
        if (news.DateEndActual <= DateOnly.FromDateTime(DateTime.UtcNow))
        {
            errors = "Дата повинна бути більша за поточну";
            Console.WriteLine(errors);
            return;
        }
        if (news.LinkSorce.Contains("https://") == false)
        {
            errors = "Посилання повинно містити https://";
            Console.WriteLine(errors);
            return;
        }
        if (isSave == true)
        {
            return;
        }
        isSave = true;
        errors = "";
        await CheckRoles();
        news.ObjectName = number;

        if (submitAction == "apply")
        {
            var result = await Http.PostAsJsonAsync("api/news/create", news);
            if (result.IsSuccessStatusCode)
            {
                Console.WriteLine("Новина успішно створена" + result);
                Snackbar.Add("Новина успішно створена!", Severity.Success);
                number = await result.Content.ReadAsStringAsync();
                Console.WriteLine("Номер новини: " + number);
            }
            else
            {
                errors = await result.Content.ReadAsStringAsync();
                Snackbar.Add("Помилка при створенні новини: " + errors, Severity.Error);
            }
        }
        else if (submitAction == "ok")
        {
            var result = await Http.PostAsJsonAsync("api/news/create", news);
            if (result.IsSuccessStatusCode)
            {
                Console.WriteLine("Новина успішно створена" + result);
                Navigation.NavigateTo("/");
            }
            else
            {
                errors = await result.Content.ReadAsStringAsync();
            }
        }
        isSave = false;
    }

    private async Task CheckRoles()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            // Перевірка стану авторизації на сервері
            await customAuth.CheckAuthenticationAsync();

            // Отримуємо ClaimsPrincipal
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                var email = user.Identity.Name;
                var roles = user.Claims
                .Where(c => c.Type == ClaimTypes.Role)
                .Select(c => c.Value)
                .ToList();

                news.username = email;

            }
            else
            {

            }
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            long maxFileSize = 1024 * 1024 * 5; // 5 МБ

            try
            {
                using var stream = file.OpenReadStream(maxFileSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);

                var buffer = ms.ToArray();
                // Формуємо рядок для відображення в
                imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";

                // Записуємо дані в модель
                news.NewsImage = Convert.ToBase64String(buffer);
                news.ImageMimeTypeOfData = file.ContentType;

                Console.WriteLine("Картинка додана!");
            }
            catch (Exception ex)
            {
                errors = $"Помилка: {ex.Message}";
            }
        }

    }
}
