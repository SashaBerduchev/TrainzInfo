@page "/register"
@using TrainzInfoShared.DTO.GetDTO
@using static System.Net.WebRequestMethods
@inject HttpClient Http
@inject NavigationManager Navigation
<PageTitle>Реєстрація | TrainzInfo</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center min-vh-100 py-12">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl w-100 shadow-xl">

        <div class="text-center mb-6">
            <div class="mud-bg-primary-lighten rounded-circle d-inline-block pa-4 mb-3">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary" Size="Size.Large" />
            </div>
            <MudText Typo="Typo.h4" Color="Color.Primary" Class="fw-bold">Створити акаунт</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Приєднуйтесь до спільноти TrainzInfo</MudText>
        </div>

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            @if (registerErrors?.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6 rounded-lg" Dense="true">
                    <ul class="mb-0 ps-3">
                        @foreach (var error in registerErrors)
                        {
                            <li><MudText Typo="Typo.caption" Color="Color.Inherit">@error.Description</MudText></li>
                        }
                    </ul>
                </MudAlert>
            }

            <MudStack Spacing="3">
                <MudTextField T="string" Label="Email адреса"
                              @bind-Value="registerModel.Email"
                              For="@(() => registerModel.Email)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              InputType="InputType.Email"
                              Immediate="true" />

                <MudTextField T="string" Label="Пароль"
                              @bind-Value="registerModel.Password"
                              For="@(() => registerModel.Password)"
                              Variant="Variant.Outlined"
                              InputType="@_passInput"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock"
                              AdornmentClickIcon="@_passIcon"
                              OnAdornmentClick="TogglePass"
                              Immediate="true" />

                <MudTextField T="string" Label="Підтвердження пароля"
                              @bind-Value="registerModel.ConfirmPassword"
                              For="@(() => registerModel.ConfirmPassword)"
                              Variant="Variant.Outlined"
                              InputType="@_passInput"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.CheckCircle"
                              Immediate="true" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Class="rounded-lg mt-4 py-3 fw-bold shadow-lg">
                    Зареєструватися
                </MudButton>

                <div class="text-center mt-4">
                    <MudText Typo="Typo.body2">
                        Вже маєте акаунт?
                        <MudLink Href="/login" Color="Color.Primary" Class="fw-bold">Увійти</MudLink>
                    </MudText>
                </div>
            </MudStack>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    bool _showPass;
    InputType _passInput = InputType.Password;
    string _passIcon = Icons.Material.Filled.VisibilityOff;
    RegisterModel registerModel = new();

    List<RegisterErrorsDTO> registerErrors = new();
    async Task HandleRegister()
    {
        var result = await Http.PostAsJsonAsync("api/auth/register", registerModel);

        if (result.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/login");
        }
        else
        {
            var message = await result.Content.ReadAsStringAsync();
            Console.WriteLine(message);
            registerErrors = await result.Content.ReadFromJsonAsync<List<RegisterErrorsDTO>>();
        }
    }

    public class RegisterModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }

    void TogglePass()
    {
        if (_showPass)
        {
            _showPass = false;
            _passIcon = Icons.Material.Filled.VisibilityOff;
            _passInput = InputType.Password;
        }
        else
        {
            _showPass = true;
            _passIcon = Icons.Material.Filled.Visibility;
            _passInput = InputType.Text;
        }
    }

}
