@page "/register"
@using TrainzInfoShared.DTO.GetDTO
@using static System.Net.WebRequestMethods
@inject HttpClient Http
@inject NavigationManager Navigation
<h3>Реєстрація</h3>

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="max-width: 450px; width: 100%;">

        <div class="text-center mb-4">
            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-block p-3 mb-2">
                <i class="bi bi-person-plus-fill text-primary fs-3"></i>
            </div>
            <h3 class="fw-bold text-dark">Створити акаунт</h3>
            <p class="text-muted small">Приєднуйтесь до нашої спільноти</p>
        </div>

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            @if (registerErrors?.Count > 0)
            {
                <div class="alert alert-danger py-2 px-3 mb-4 rounded-3" role="alert">
                    <ul class="mb-0 small ps-3">
                        @foreach (var error in registerErrors)
                        {
                            <li>@error.Description</li>
                        }
                    </ul>
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-medium small">Email адреса</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                    <input @bind="registerModel.Email"
                           type="email"
                           placeholder="example@mail.com"
                           class="form-control border-start-0 bg-light shadow-none" />
                </div>
                <ValidationMessage For="@(() => registerModel.Email)" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-medium small">Пароль</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-shield-lock"></i></span>
                    <input @bind="registerModel.Password"
                           type="password"
                           placeholder="••••••••"
                           class="form-control border-start-0 bg-light shadow-none" />
                </div>
                <ValidationMessage For="@(() => registerModel.Password)" class="text-danger small" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-medium small">Підтвердження пароля</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-check-circle"></i></span>
                    <input @bind="registerModel.ConfirmPassword"
                           type="password"
                           placeholder="••••••••"
                           class="form-control border-start-0 bg-light shadow-none" />
                </div>
                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="text-danger small" />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm rounded-3 hover-lift">
                Зареєструватися
            </button>

            <div class="text-center mt-4">
                <p class="small text-muted mb-0">Вже маєте акаунт? <a href="/login" class="text-primary fw-bold text-decoration-none">Увійти</a></p>
            </div>
        </EditForm>
    </div>
</div>

@code {
    RegisterModel registerModel = new();

    List<RegisterErrorsDTO> registerErrors = new();
    async Task HandleRegister()
    {
        var result = await Http.PostAsJsonAsync("api/auth/register", registerModel);

        if (result.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/login");
        }
        else
        {
            var message = await result.Content.ReadAsStringAsync();
            Console.WriteLine(message);
            registerErrors = await result.Content.ReadFromJsonAsync<List<RegisterErrorsDTO>>();
        }
    }

    public class RegisterModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
