@model TrainzInfo.Models.DizelTrainzList

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>DizelTrainzList</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                @Html.DisplayName("Название")
                @Html.DropDownList("Name", ViewBag.names as SelectList, htmlAttributes: new { @class = "form-control" })
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Номер")
                <input asp-for="NumberTrain" class="form-control" />
                <span asp-validation-for="NumberTrain" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Депо приписки")
                @Html.DropDownList("Depo", ViewBag.depots as SelectList, htmlAttributes: new { @class = "form-control" })
                <span asp-validation-for="Depo" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Статус")
                @Html.DropDownList("Status", ViewBag.status as SelectList, htmlAttributes: new { @class = "form-control" })
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Картинка(ссылка)")
                <input asp-for="Imgsrc" class="form-control" />
                <span asp-validation-for="Imgsrc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
<style>
    body {
        background: url(https://klike.net/uploads/posts/2020-04/1586763576_18.jpg);
    }
</style>

