@{
    ViewData["Title"] = "Home Page";
}

    <div class="text-center">
        <h1 class="display-4">Добро пожаловать!</h1>
        @*<p>Learn about <a href="https://docs.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>*@
        <p ><big> Данный сайт посвящается любителям железнодорожного транспорта, любителям поездов, электричек, электовозов и тепловозов.
            Здесь вы найдете много интересной информации о железнодорожном транспорте и новости</big>
        </p>
        <a class="btn btn-info" asp-controller="NewsInfoes" asp-action="Create">Создать новость</a> 


    </div>
<body>
    <div class="text-center">
        <p>
         
        <img src="https://upload.wikimedia.org/wikipedia/commons/4/4e/%D0%A7%D0%A18-082%2C_%D0%A3%D0%BA%D1%80%D0%B0%D0%B8%D0%BD%D0%B0%2C_%D0%9A%D0%B8%D0%B5%D0%B2%2C_%D1%81%D1%82%D0%B0%D0%BD%D1%86%D0%B8%D1%8F_%D0%9A%D0%B8%D0%B5%D0%B2-%D0%9F%D0%B0%D1%81%D1%81%D0%B0%D0%B6%D0%B8%D1%80%D1%81%D0%BA%D0%B8%D0%B9_%28Trainpix_207464%29.jpg" width="900" height="650" alt="Железная дорога" title="Электровоз ЧС8"/>
            </p>
    </div>
    <table class="table">
        <thead>
            <tr>

                <th>
                    @Html.DisplayName("Картинка")
                </th>
                <th>
                    @Html.DisplayName("Название")
                </th>
                <th>
                    @Html.DisplayName("Общее")
                </th>
                <th>
                    @Html.DisplayName("Дата")
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (NewsInfo item in Model)
            {
            <tr>

                <td>
                    <img src="@item.Imgsrc" width="130" height="100" />
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.NameNews)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.BaseNewsInfo)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DateTime)
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="NewsInfoes" asp-action="Details" asp-route-id="@item.id">Смотреть полную статью</a>
                    @*<a asp-action="Details" asp-route-id="@item.id">Детальная информация</a>*@
                    @*<a asp-action="Delete" asp-route-id="@item.id">Удалить</a>*@
                    <a class="btn btn-danger" asp-controller="NewsInfoes" asp-action="Delete" asp-route-id="@item.id">Delete</a>

                </td>
            </tr>
            }
        </tbody>
    </table>
</body>
