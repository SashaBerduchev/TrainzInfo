@model TrainzInfo.Models.ElectricTrain

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>ElectricTrain</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="VagonsCountP" class="control-label"></label>
                <input asp-for="VagonsCountP" class="form-control" />
                <span asp-validation-for="VagonsCountP" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaxSpeed" class="control-label"></label>
                <input asp-for="MaxSpeed" class="form-control" />
                <span asp-validation-for="MaxSpeed" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Депо приписки")
                @Html.DropDownList("DepotTrain", ViewBag.depots as SelectList)
                <span asp-validation-for="VagonsCountP" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastKvr" class="control-label"></label>
                <input type="date" asp-for="LastKvr" class="form-control" />
                <span asp-validation-for=LastKvr class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Created" class="control-label"></label>
                <input type="date" asp-for="Created" class="form-control" />
                <span asp-validation-for=Created class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Plant" class="control-label"></label>
                @Html.DropDownList("Plant", ViewBag.plants as SelectList)
                <span asp-validation-for=Plant class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PlaceKvr" class="control-label"></label>
                @Html.DropDownList("PlaceKvr", ViewBag.plants as SelectList)
                <span asp-validation-for=PlaceKvr class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Imgsrc" class="control-label"></label>
                <input asp-for="Imgsrc" class="form-control" />
                <span asp-validation-for="Imgsrc" class="text-danger"></span>
            </div>
            <div>
                <a class="btn btn-info" target="_blank" asp-controller="Plants" asp-action="Create">Добавить завод</a>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

<style>
    body {
        background: url(https://klike.net/uploads/posts/2020-04/1586763576_18.jpg);
    }
</style>