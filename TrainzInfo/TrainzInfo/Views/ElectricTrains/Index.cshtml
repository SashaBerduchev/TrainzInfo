@model IEnumerable<TrainzInfo.Models.ElectricTrain>

@{
    ViewData["Title"] = "Index";
}

<h1>Электрички</h1>
<head>
    <link rel="stylesheet" href="">
</head>
<p>
    <a class="btn btn-outline-info" asp-action="Create">Создать</a>
    
</p>
<div>
    @foreach (var item in Model)
    {
    <div style="font-size:25px; height:270px; margin:20px; background-color:aliceblue">
        <div style="margin:20px; position:relative; top:10px;"><img src="@item.Imgsrc" width="390" height="250" /> </div>
        <div style="position:relative; left:420px; top:-220px">
            <div>@Html.DisplayName("Название: ") @Html.DisplayFor(modelItem => item.Name) - @Html.DisplayFor(modelItem => item.Model)</div>
            <div>@Html.DisplayName("Колчество вагонов: ")@Html.DisplayFor(modelItem => item.VagonsCountP)</div>
            <div>@Html.DisplayName("Максимальная скорость: ")@Html.DisplayFor(modelItem => item.MaxSpeed)</div>
            <div>@Html.DisplayName("Депо: ") @Html.DisplayFor(modelitem => item.DepotTrain)</div>
            <div>@Html.DisplayName("Город: ") @Html.DisplayFor(modelitem => item.DepotCity)</div>
        </div>
        <div style="position:relative; left:800px; top:-400px">
            <a class="btn btn-info" asp-action="Details" asp-route-id="@item.id">Подробно</a>
        </div>
    </div>
    }
</div>

<style>
    td {
        background: #6a5eff; /* Цвет фона */
        position: center;
        padding: 5px; /* Поля в ячейках */
        opacity: 1.9; /* Полупрозрачность таблицы */
        filter: alpha(Opacity=50); /* Для IE */
        width: 700px;
        color: white;
        text-decoration: solid;
    }
</style>
<style>
    body {
        background: url(https://klike.net/uploads/posts/2020-04/1586763576_18.jpg);
    }
</style>
