@model TrainzInfo.Models.ElectricTrain

@{
    ViewData["Title"] = "Create";
}

<h1>Добавить  </h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @*<div class="form-inline">
                @Html.DropDownList("User", ViewBag.users as SelectList, htmlAttributes: new { @class = "form-control" })
            </div>*@
            <div class="form-group">
                @Html.DisplayName("Название")
                @Html.DropDownList("Name", ViewBag.models as SelectList, htmlAttributes: new { @class = "form-control" })

                @if (ViewBag.user != null)
                {
                    if (ViewBag.user.Role == "Superadmin" || ViewBag.user.Role == "Admin")
                    {
                        <div>
                            <a class="btn btn-outline-info" target="_blank" asp-controller="SuburbanTrainsInfoes" asp-action="Create">Добавить серию поездов</a>
                        </div>
                    }
                }
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Номер")
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Колличество вагонов")
                <input asp-for="VagonsCountP" class="form-control" />
                <span asp-validation-for="VagonsCountP" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Депо приписки")
                @Html.DropDownList("DepotTrain", ViewBag.depots as SelectList, htmlAttributes: new { @class = "form-control" })
                @if (ViewBag.user != null)
                {
                    if (ViewBag.user.Role == "Superadmin" || ViewBag.user.Role == "Admin")
                    {
                        <div>
                            <a class="btn btn-outline-info" target="_blank" asp-controller="DepotLists" asp-action="Create">Добавить название предприятия</a>
                        </div>
                    }
                }
                <span asp-validation-for="VagonsCountP" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Макимальная скорость")
                <input asp-for="MaxSpeed" class="form-control" />
                <span asp-validation-for="MaxSpeed" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Год создания");
                <input type="date" asp-for="Created" class="form-control" />
                <span asp-validation-for=Created class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Завод постройки");
                @Html.DropDownList("Plant", ViewBag.plants as SelectList, htmlAttributes: new { @class = "form-control" })
                @if (ViewBag.user != null)
                {
                    if (ViewBag.user.Role == "Superadmin" || ViewBag.user.Role == "Admin")
                    {
                        <div>
                            <a class="btn btn-outline-info" target="_blank" asp-controller="Plants" asp-action="Create">Добавить название предприятия</a>
                        </div>
                    }
                }
                <span asp-validation-for=Plant class="text-danger"></span>
            </div>

            <div class="form-group">
                @Html.DisplayName("Последний КВР(год)");
                <input type="date" asp-for="LastKvr" class="form-control" />
                <span asp-validation-for=LastKvr class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Завод проводивший КВР");
                @Html.DropDownList("PlaceKvr", ViewBag.plants as SelectList)
                <span asp-validation-for=PlaceKvr class="text-danger"></span>
            </div>
            <div>
                <a class="btn btn-info" target="_blank" asp-controller="Plants" asp-action="Create">Добавить завод</a>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
<style>
    body {
        background: url(https://klike.net/uploads/posts/2020-04/1586763576_18.jpg);
    }
</style>
