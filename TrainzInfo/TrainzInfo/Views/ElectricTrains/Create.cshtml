            </div>
            <div class="form-group">
                <label asp-for="VagonsCountP" class="control-label"></label>
                <input asp-for="VagonsCountP" class="form-control" />
                <span asp-validation-for="VagonsCountP" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaxSpeed" class="control-label"></label>
                <input asp-for="MaxSpeed" class="form-control" />
                <span asp-validation-for="MaxSpeed" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Imgsrc" class="control-label"></label>
                <input asp-for="Imgsrc" class="form-control" />
                <span asp-validation-for="Imgsrc" class="text-danger"></span>
            </div>
