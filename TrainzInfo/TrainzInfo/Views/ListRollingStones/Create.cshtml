@model TrainzInfo.Models.ListRollingStone

@{
    ViewData["Title"] = "Create";
}

<h1>Создать</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label" />
                @*<input asp-for="Name" class="form-control" />*@
                @Html.DropDownList("Name", ViewBag.locomotives as SelectList)
                <a class="btn btn-info" asp-controller="Electic_locomotive" asp-action="Create">Добавить электровоз</a>
                <a class="btn btn-info" asp-controller="DieselLocomoives" asp-action="Create">Добавить тепловоз</a>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Депо приписки   ")
                @*<input asp-for="Depot" class="form-control" />*@
                @Html.DropDownList("Depot", ViewBag.depots as SelectList)
                <span asp-validation-for="Depot" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Город")
                @Html.DropDownList("City", ViewBag.citys as SelectList)
                <span asp-validation-for="City" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                @Html.DropDownList("Status", ViewBag.status as SelectList)
                <a class="btn btn-success" asp-controller="Status" asp-action="Create">Добавить статус</a>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Photo" class="control-label"></label>
                <input asp-for="Photo" class="form-control" />
                <span asp-validation-for="Photo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

