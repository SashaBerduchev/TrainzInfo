@model TrainzInfo.Models.NewsInfo

@{
    ViewData["Title"] = "Details";
}
<h1>@Model.NameNews</h1>
<head>
    <meta charset="utf-8">
    <title>Фон</title>
    <style>
        body {
            background: url(https://encrypted-tbn0.gstatic.com/images?q=tbn%3AANd9GcScDNWcFxHDwgif3KnEeJTBP0qABTnFDcaf28vXTq_KqkdFsT87&usqp=CAU);
        }
    </style>
</head>
<div>
    <hr />
    <dl class="row">
        <dd class="col-sm-10">
            @*@Html.DisplayFor(model => model.Imgsrc)*@
            <img src="@Model.Imgsrc" width="800" height="550" />
        </dd>
        <dt class="col-sm-2">
            @*@Html.DisplayNameFor(model => model.NameNews)*@
        </dt>
        <dd class="col-sm-10" style="        font-size: 25px
">
            @Html.DisplayFor(model => model.NameNews)
        </dd>
        <dt class="col-sm-2">
            @*@Html.DisplayNameFor(model => model.BaseNewsInfo)*@
        </dt>
        <dd class="col-sm-10" style="        font-size: 25px
">
            @Html.DisplayFor(model => model.BaseNewsInfo)
        </dd>
        <dt class="col-sm-2">
            @*@Html.DisplayNameFor(model => model.NewsInfoAll)*@
        </dt>
        <dd class="col-sm-10" style="font-size: 25px">
            @Html.DisplayFor(model => model.NewsInfoAll)
        </dd>
    </dl>
</div>
<div>

    <a class="btn btn-info" asp-controller="NewsComments" asp-action="Edit" asp-route-id="@Model.id">Комментировать</a>
    <a class="btn btn-info" asp-controller="NewsComments" asp-action="Index" asp-route-idnews="@Model.id">Комментарии + @Convert.ToString(ViewBag.count)</a>
    @if (Model != null)
    {
        <a asp-action="Edit" asp-route-id="@Model.id">Редактировать информацию</a>
    }
    else
    {
        <meta http-equiv="refresh" content="900">

    }
    <a asp-action="Index">Вернутся обратно</a>
</div>
<style>
        row {
            background: #c7b39b url(@Model.Imgsrc); /* Цвет фона и путь к файлу */
            color: #fff; /* Цвет текста */
        }
</style>
