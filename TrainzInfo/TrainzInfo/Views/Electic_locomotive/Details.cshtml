@model TrainzInfo.Models.Electic_locomotive

@{
    ViewData["Title"] = "Details";
}

<h1>@Model.Name</h1>

<div>
    <h4>Электровоз</h4>
    <hr />
    <a asp-controller="Electrick_Lockomotive_Info" asp-action="Details" asp-route-idloc="@Model.id">Подробная информация обэлектровозе @Model.Name</a>
    <dl class="">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Speed)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Speed)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SectionCount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SectionCount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ALlPowerP)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ALlPowerP)
        </dd>
        <dd class="col-sm-10">
            @*@Html.DisplayFor(model => model.ALlPowerP)*@
            <img src="@Model.LocomotiveImg" width="900" height="600">
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
