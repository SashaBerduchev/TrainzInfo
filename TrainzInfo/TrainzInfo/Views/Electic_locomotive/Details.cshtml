@model TrainzInfo.Models.Electic_locomotive

@{
    ViewData["Title"] = "Details";
}

<h1>@Model.Seria</h1>
<style>
    body {
        background: url(https://encrypted-tbn0.gstatic.com/images?q=tbn%3AANd9GcScDNWcFxHDwgif3KnEeJTBP0qABTnFDcaf28vXTq_KqkdFsT87&usqp=CAU);
    }
</style>
<div>
    <h4>Электровоз</h4>
    <hr />
    <a asp-controller="Electrick_Lockomotive_Info" asp-action="Details" asp-route-idloc="@Model.id">Подробная информация обэлектровозе @Model.Seria</a>
    <dl class="">
        <dt class="col-sm-2">
            @Html.DisplayName("Электровоз")
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayName(Model.Seria + " - " +Model.Number)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Speed)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Speed)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SectionCount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SectionCount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ALlPowerP)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ALlPowerP)
        </dd>
        <dd class="col-sm-10">
            @*@Html.DisplayFor(model => model.ALlPowerP)*@
            <img src="@Model.LocomotiveImg" width="900" height="600">
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
