@model IEnumerable<TrainzInfo.Models.Electic_locomotive>

@{
    ViewData["Title"] = "Index";
}

<h1>Электровозы</h1>
<style>
    body {
        background: url(https://upload.wikimedia.org/wikipedia/commons/4/4e/%D0%A7%D0%A18-082%2C_%D0%A3%D0%BA%D1%80%D0%B0%D0%B8%D0%BD%D0%B0%2C_%D0%9A%D0%B8%D0%B5%D0%B2%2C_%D1%81%D1%82%D0%B0%D0%BD%D1%86%D0%B8%D1%8F_%D0%9A%D0%B8%D0%B5%D0%B2-%D0%9F%D0%B0%D1%81%D1%81%D0%B0%D0%B6%D0%B8%D1%80%D1%81%D0%BA%D0%B8%D0%B9_%28Trainpix_207464%29.jpg);
        color: #fff; /* Цвет текста */
    }
</style>
<p>
    <a asp-action="Create">Добавить электровоз</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Название")
            </th>
            <th>
                @Html.DisplayName("Скорость")
            </th>
            <th>
                @Html.DisplayName("Колличество секций")
            </th>
            <th>
                @Html.DisplayName("Мощность")
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Speed)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SectionCount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ALlPowerP)
            </td>
            <td>
                <img src="@item.LocomotiveImg" width="180" height="120" />
            </td>
            <td>
                @*<a asp-action="Edit" asp-route-id="@item.id">Edit</a> |*@
                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.id">Детальная информация</a>
                <a class="btn btn-outline-primary" asp-controller="ListRollingStones" asp-action="Index" asp-route-idlocname="@item.Name">Смотреть перечень локомотивов @item.Name</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.id">Удалить</a>
                <a class="btn btn-outline-success" asp-controller="UserLocomotivePhotos" asp-action="Index" asp-route-name="@item.Name">Фото пользователей</a>
            </td>
        </tr>
}
    </tbody>
</table>
<style type="text/css">
    td {
        background: #fff; /* Цвет фона */
        padding: 5px; /* Поля в ячейках */
        opacity: 0.8; /* Полупрозрачность таблицы */
        filter: alpha(Opacity=50); /* Для IE */
        width 700;
        color: black;
        text-decoration: solid;
    }
</style>