@model IEnumerable<TrainzInfo.Models.Electic_locomotive>

@{
    ViewData["Title"] = "Index";
}

<h1>Электровозы</h1>

<p>
    <a asp-action="Create">Добавить электровоз</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Speed)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SectionCount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ALlPowerP)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Speed)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SectionCount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ALlPowerP)
            </td>
            <td>
                @*<a asp-action="Edit" asp-route-id="@item.id">Edit</a> |*@
                <a asp-action="Details" asp-route-id="@item.id">Детальная информация</a> |
                @*<a asp-action="Delete" asp-route-id="@item.id">Delete</a>*@
            </td>
        </tr>
}
    </tbody>
</table>
