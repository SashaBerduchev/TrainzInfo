@model TrainzInfo.Models.Electrick_Lockomotive_Info

@{
    ViewData["Title"] = "Details";
}

<h1>@Model.Name</h1>

<div>
    <h4>@Model.Name</h4>
    <a asp-controller="ListRollingStones" asp-action="Edit" asp-route-idlocname=@Model.Name>Добавыить электровоз @Model.Name </a> || 
    <a asp-controller="ListRollingStones" asp-action="Index" asp-route-idlocname=@Model.Name>Список электровозов @Model.Name</a>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Electric_Type)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Electric_Type)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Power)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Power)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Baseinfo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Baseinfo)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AllInfo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AllInfo)
        </dd>
    </dl>
</div>
<div>
    @if (Model != null){
        <a asp-action="Edit" asp-route-id="@Model.id">Редактировать</a>
      }
    else
    {
        <meta http-equiv="refresh" content="600">
    }
    <a asp-action="Index">Back to List</a>
</div>
