@model IEnumerable<TrainzInfo.Models.Diesel_trainz>

@{
    ViewData["Title"] = "Index";
}

<h1>Дизель-поезда</h1>

<p>
    <a asp-action="Create">Создать новый</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Название")
            </th>
            <th>
                @Html.DisplayName("Количество вагонов")
            </th>
            <th>
                @Html.DisplayName("Мощность двигателя")
            </th>
            <th>
                @Html.DisplayName("Картинка")
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.VagonCount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Power)
            </td>
            <td>
                <img src="@item.ImgSrc" width="180" height="120">
            </td>
            <td>
                <a class="btn btn-info" asp-controller="DieselTrainzLists" asp-action="Index" asp-route-name="@item.Name">Список подвижного состава</a>
                <a asp-action="Edit" asp-route-id="@item.id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
<style>
    body {
        background: url(https://encrypted-tbn0.gstatic.com/images?q=tbn%3AANd9GcScDNWcFxHDwgif3KnEeJTBP0qABTnFDcaf28vXTq_KqkdFsT87&usqp=CAU);
    }
</style>