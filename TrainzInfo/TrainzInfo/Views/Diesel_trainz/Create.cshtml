@model TrainzInfo.Models.Diesel_trainz

@{
    ViewData["Title"] = "Create";
}

<h1>Дизель-поезд</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                @Html.DisplayName("Название")
                @*<label asp-for="Name" class="control-label"></label>*@
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Количество вагонов")
                @*<label asp-for="VagonCount" class="control-label"></label>*@
                <input asp-for="VagonCount" class="form-control" />
                <span asp-validation-for="VagonCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Мощность двигателя")
                @*<label asp-for="Power" class="control-label"></label>*@
                <input asp-for="Power" class="form-control" />
                <span asp-validation-for="Power" class="text-danger"></span>
            </div>
            <div class="form-group">
                @Html.DisplayName("Картинка")
                @*<label asp-for="ImgSrc" class="control-label"></label>*@
                <input asp-for="ImgSrc" class="form-control" />
                <span asp-validation-for="ImgSrc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
