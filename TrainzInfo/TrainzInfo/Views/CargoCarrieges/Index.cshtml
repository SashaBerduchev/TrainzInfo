@model IEnumerable<TrainzInfo.Models.CargoCarrieges>

@{
    ViewData["Title"] = "Товарный вагон";
}

    <h1>Товарный вагон</h1>

<p>
    <a asp-action="Create">Добавить новый</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Тип вагона")
            </th>
            <th>
                @Html.DisplayName("Конструкционная скорость")
            </th>
            <th>
                @Html.DisplayName("Тип перевозимых грузов")
            </th>
            <th>
                @Html.DisplayName("Вес груза")
            </th>
            <th></th>
        </tr>
        
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.CarriegeType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaxSpeed)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CargoType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CargoWeight)
            </td>
            <td>
                <img src="@item.Imgsrc" width="170" height="150"/>
            </td>
            <td>
                @if (Model != null)
                {
                    <a class="btn btn-outline-info" asp-controller="CargoCarriegesInfoes" asp-action="Details" asp-route-idcar="@item.id">Долнительная информация</a>
                    <a class="btn btn-outline-success" asp-action="Edit" asp-route-id="@item.id"> Редактировать </a>
                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.id"> Удалить  </a>
                }
                else
                {
                    <meta http-equiv="refresh" content="600">
                }
            </td>
        </tr>
}
    </tbody>
</table>
