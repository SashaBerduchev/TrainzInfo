@model TrainzInfo.Models.RailwayUsersPhoto

@{
    ViewData["Title"] = "Добавить раздел";
}



<head>

    <title>Create</title>
</head>
<body>

    
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <h2>Выбрать перегон или станцию</h2>
                <div class="form-group">
                    @Html.DisplayName("Выбрать начальную станцию или станцию на которой сдлано фото")
                    @Html.DropDownList("CityFrom", ViewBag.stations as SelectList, htmlAttributes: new { @class = "form-control" })
                    <span asp-validation-for="CityFrom" class="text-danger"></span>
                </div>
                <div class="form-group">
                    @Html.DisplayName("Конечная станция перегона")
                    @Html.DropDownList("CitytTo", ViewBag.stations as SelectList, htmlAttributes: new { @class = "form-control" })
                    <span asp-validation-for="CitytTo" class="text-danger"></span>
                </div>
                <div class="form-group">
                    @Html.DisplayName("Общая информация")
                    <textarea style="width:700px; height:400px" asp-for="Information" class="form-control" ></textarea>
                    <span asp-validation-for="Information" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Сохранить и загрузить картинку" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div>
        <a class="btn btn-block" asp-action="Index">Вернутся</a>
    </div>

</body>
<style>
    body {
        background: url(https://klike.net/uploads/posts/2020-04/1586763576_18.jpg);
    }
</style>
